---
import { siteConfig } from "../config";
const hasAbout = siteConfig.about && siteConfig.about.length > 0;
---

{
  hasAbout && (
    <section id="about" class="w-full">
      <h2 class="text-xl font-bold text-gray-900 mb-6">About</h2>
      
      <div class="about-card scroll-reveal">
        <div class="space-y-4">
          {siteConfig.about.map((paragraph) => (
            <p class="text-mono text-sm leading-relaxed text-gray-600">
              {paragraph}
            </p>
          ))}
        </div>

        <div class="mt-8 inline-flex flex-col items-center gap-2">
          <a href="https://codolio.com/profile/_SarvagyaGupta" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-14 h-14 border border-gray-200 rounded-xl hover:bg-gray-50 hover:shadow-sm transition-all bg-white">
            <img src="/{FBFD58A1-4BC2-426C-9765-953B6AC1368A}.png" alt="Codolio" class="w-8 h-8 object-contain" />
          </a>
          <span class="text-xs font-medium text-gray-500 font-sans">Coding Profile</span>
        </div>
      </div>
    </section>
  )
}

<style>
  .about-btn {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 16px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: #4b5563;
    background: transparent;
    transition: all 0.2s ease;
  }

  .about-btn:hover {
    background: #f3f4f6;
    color: #111827;
  }
</style>
