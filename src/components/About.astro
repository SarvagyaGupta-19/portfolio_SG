---
import { siteConfig } from "../config";
---

<section id="about" class="px-8 sm:px-12 md:px-16 lg:px-24">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
      <div class="lg:col-span-4 scroll-reveal-left">
        <h2
          class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900"
          style="line-height: 1.2; margin-bottom: 1rem;"
        >
          About Me
        </h2>
        <div
          class="w-[75px] h-[5px] rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        >
        </div>
      </div>

      <div class="lg:col-span-8 scroll-reveal-right">
        <p class="text-lg sm:text-xl leading-relaxed text-gray-700" style="line-height: 1.8; text-align: justify; text-justify: inter-word; white-space: pre-line;">
          {siteConfig.aboutMe}
        </p>
        
        {/* Tech Profile */}
        {siteConfig.social?.codolio && (
          <div class="mt-8">
            <p class="text-sm font-medium text-gray-600 mb-3">Tech Profile:</p>
            <div class="flex gap-4">
              <a
                href={siteConfig.social.codolio}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Codolio Tech Profile"
                class="tech-profile-icon group"
                title="View Tech Profile"
              >
                <div class="icon-container">
                  <img 
                    src="/codolio-owl.png" 
                    alt="Tech Profile" 
                    class="icon-image"
                  />
                </div>
              </a>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  /* Tech profile icon styles - matching Hero section exactly */
  .tech-profile-icon {
    display: inline-flex;
    text-decoration: none;
    position: relative;
  }

  .tech-profile-icon .icon-container {
    position: relative;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    border: 2px solid rgba(229, 231, 235, 0.6);
    border-radius: 14px;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    overflow: hidden;
    color: #8B4049;
  }

  .tech-profile-icon .icon-container::before {
    content: '';
    position: absolute;
    inset: 0;
    background: currentColor;
    opacity: 0;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    border-radius: 12px;
  }

  .tech-profile-icon .icon-image {
    width: 36px;
    height: 36px;
    object-fit: contain;
    position: relative;
    z-index: 1;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .tech-profile-icon:hover .icon-container {
    transform: translateY(-4px) scale(1.05);
    border-color: transparent;
    box-shadow: 0 12px 28px -8px currentColor;
  }

  .tech-profile-icon:hover .icon-container::before {
    opacity: 0.1;
  }

  .tech-profile-icon:hover .icon-image {
    transform: scale(1.1) rotate(5deg);
  }
</style>
