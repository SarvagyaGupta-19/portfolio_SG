---
import { siteConfig } from "../config";

const hasSkillCategories = siteConfig.skillCategories && siteConfig.skillCategories.length > 0;
---

{hasSkillCategories && (
  <div id="skills" class="relative w-full overflow-hidden bg-white py-24">
    {/* Subtle Background Pattern */}
    <div class="absolute inset-0 opacity-5">
      <div class="absolute left-1/4 top-1/4 h-96 w-96 rounded-full bg-[var(--accent-color)] blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 h-96 w-96 rounded-full bg-[#fbbc04] blur-3xl"></div>
    </div>

    <div class="container relative z-10 mx-auto max-w-7xl px-6">
      {/* Section Header */}
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-4xl font-bold text-gray-900 md:text-5xl">
          Skills & <span class="text-[var(--accent-color)]">Expertise</span>
        </h2>
        <p class="mx-auto max-w-3xl text-lg text-gray-600 leading-relaxed">
          Comprehensive overview of my technical skills and expertise as an ML Engineer: LLMs, RAGs, NLP, Computer Vision, MLOps, Cloud & DevOps
        </p>
      </div>

      {/* Skills Categories Grid */}
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
        {siteConfig.skillCategories.map((category, index) => (
          <div 
            class="group relative overflow-hidden rounded-2xl bg-white p-8 shadow-md transition-all duration-300 hover:shadow-xl border border-gray-200"
            style={`animation-delay: ${index * 100}ms`}
          >
            {/* Minimal Border Accent on Hover */}
            <div class="absolute inset-0 rounded-2xl border-2 border-transparent transition-all group-hover:border-[var(--accent-color)]/30"></div>
            
            <div class="relative z-10">
              {/* Category Title */}
              <h3 class="mb-6 flex items-center gap-3 text-2xl font-bold text-gray-900">
                <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--accent-color)]/10 text-[var(--accent-color)]">
                  {index === 0 && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="16 18 22 12 16 6"></polyline>
                      <polyline points="8 6 2 12 8 18"></polyline>
                    </svg>
                  )}
                  {index === 1 && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                      <polyline points="7.5 4.21 12 6.81 16.5 4.21"></polyline>
                      <polyline points="7.5 19.79 7.5 14.6 3 12"></polyline>
                      <polyline points="21 12 16.5 14.6 16.5 19.79"></polyline>
                      <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                      <line x1="12" y1="22.08" x2="12" y2="12"></line>
                    </svg>
                  )}
                  {index === 2 && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                      <path d="M2 17l10 5 10-5"></path>
                      <path d="M2 12l10 5 10-5"></path>
                    </svg>
                  )}
                  {index === 3 && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10"></circle>
                      <line x1="2" y1="12" x2="22" y2="12"></line>
                      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                    </svg>
                  )}
                  {index === 4 && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
                      <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
                      <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
                    </svg>
                  )}
                  {index === 5 && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
                    </svg>
                  )}
                </span>
                <span>{category.category}</span>
              </h3>

              {/* Skills Tags */}
              <div class="flex flex-wrap gap-3">
                {category.skills.map((skill) => (
                  <span class="skill-tag-minimal rounded-full border border-gray-300 bg-gray-50 px-4 py-2 text-sm font-medium text-gray-700 transition-all duration-200 hover:border-[var(--accent-color)] hover:bg-[var(--accent-color)]/5 hover:text-[var(--accent-color)]">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Additional Info */}
      <div class="mt-16 text-center">
        <p class="text-lg text-gray-600">
          <span class="font-semibold text-[var(--accent-color)]">Currently Learning:</span> Federated Learning, Advanced LLM Architectures, Rust for ML Systems
        </p>
      </div>
    </div>
  </div>
)}

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  :root {
    --accent-color: var(--accentColor);
  }
  
  @keyframes pulse {
    0%, 100% {
      opacity: 0.2;
    }
    50% {
      opacity: 0.4;
    }
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  /* Minimal Google-inspired skill tag hover effect - Enhanced */
  .skill-tag-minimal {
    position: relative;
    overflow: visible;
  }

  .skill-tag-minimal::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    padding: 2px;
    background: linear-gradient(135deg, #4285f4 0%, #ea4335 25%, #fbbc04 50%, #34a853 75%, #4285f4 100%);
    background-size: 200% 200%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.4s ease, background-position 0.6s ease;
    pointer-events: none;
  }

  .skill-tag-minimal:hover::after {
    opacity: 1;
    background-position: 100% 100%;
    animation: borderGlow 1.5s ease-in-out infinite;
  }

  @keyframes borderGlow {
    0%, 100% {
      filter: brightness(1);
    }
    50% {
      filter: brightness(1.3);
    }
  }

  .skill-tag-minimal:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 4px 16px rgba(66, 133, 244, 0.25),
                0 2px 8px rgba(234, 67, 53, 0.15),
                0 1px 4px rgba(251, 188, 4, 0.15);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .skill-tag-google:hover {
    transform: translateY(-4px) scale(1.1);
    font-weight: 600;
  }

  /* Add ripple animation on click */
  @keyframes ripple {
    0% {
      transform: translate(-50%, -50%) scale(0);
      opacity: 1;
    }
    100% {
      transform: translate(-50%, -50%) scale(4);
      opacity: 0;
    }
  }
</style>
