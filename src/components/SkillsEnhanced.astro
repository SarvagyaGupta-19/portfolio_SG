---
import { siteConfig } from "../config";

const hasSkillCategories = siteConfig.skillCategories && siteConfig.skillCategories.length > 0;
const totalSkills = siteConfig.skillCategories.reduce((sum, cat) => sum + cat.skills.length, 0);

const getCategoryIcon = (category: string) => {
  switch (category) {
    case "AI/ML/DL":
      return `<path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" /><circle cx="12" cy="12" r="4" />`;
    case "Python Libs":
      return `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line>`;
    case "GenAI & LLMs":
      return `<path d="m4 14 1.5-3.5 3.5-1.5-3.5-1.5L4 4 2.5 7.5.5 9l3.5 1.5Z"/><path d="m15.5 21 2-5 5-2-5-2-2-5-2 5-5 2 5 2Z"/><path d="m11 9 1-2 2-1-2-1-1-2-1 2-2 1 2 1Z"/>`;
    case "Cloud":
      return `<path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z" />`;
    case "Databases":
      return `<ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" /><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />`;
    case "Languages":
      return `<polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />`;
    case "Dev Tools":
      return `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />`;
    default:
      return `<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" /><polyline points="14 2 14 8 20 8" />`;
  }
};
---

{
  hasSkillCategories && (
    <section id="skills" class="w-full">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Skills</h2>

      <!-- Filter Tabs -->
      <div class="flex flex-wrap gap-2 mb-6" id="skill-tabs">
        <button
          class="skill-tab active"
          data-category="all"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2A10 10 0 1 0 22 12A10 10 0 0 0 12 2Z" />
            <path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
            <path d="M12 2v7" />
            <path d="M22 12h-7" />
            <path d="M12 22v-7" />
            <path d="M2 12h7" />
          </svg>
          All Skills
          <span class="tab-count">{totalSkills}</span>
        </button>
        {siteConfig.skillCategories.map((cat) => (
          <button
            class="skill-tab"
            data-category={cat.category}
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
            </svg>
            {cat.category}
            <span class="tab-count">{cat.skills.length}</span>
          </button>
        ))}
      </div>

      <!-- Skills Container Card -->
      <div class="skills-container scroll-reveal">
        <div class="flex flex-wrap justify-center gap-3" id="skills-cloud">
          {siteConfig.skillCategories.map((cat) =>
            cat.skills.map((skill) => (
              <span
                class="skill-chip"
                data-category={cat.category}
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={getCategoryIcon(cat.category)} />
                {skill}
              </span>
            ))
          )}
        </div>

        <p class="text-center text-sm text-gray-500 font-mono mt-8" id="skill-count">
          Showing {totalSkills} total skills
        </p>
      </div>
    </section>
  )
}

<style>
  .skill-tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: 1px solid transparent;
    border-radius: 9999px;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    color: #4b5563;
    background: #f3f4f6; /* bg-muted */
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .skill-tab:hover {
    background: #e5e7eb; /* hover:bg-muted/80 */
  }

  .skill-tab.active {
    background: #111827; /* bg-primary */
    color: #ffffff; /* text-primary-foreground */
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  .skill-tab.active .tab-count {
    background: #ffffff;
    color: #111827;
  }

  .tab-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    border-radius: 10px;
    font-size: 0.7rem;
    font-weight: 600;
    background: #e5e7eb;
    color: #4b5563;
    transition: all 0.2s ease;
  }

  .skills-container {
    border: 1px solid #f0f0f0;
    border-radius: 12px;
    padding: 2.5rem 2rem;
    background: #fcfcfc; /* subtle light background */
  }

  .skill-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    color: #1f2937;
    background: #ffffff;
    transition: all 0.2s ease;
    cursor: default;
  }

  .skill-chip:hover {
    border-color: #d1d5db;
    background: #f9fafb;
  }

  .skill-chip.hidden-skill {
    display: none;
  }

  .skill-chip svg {
    color: #6b7280;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.skill-tab');
    const chips = document.querySelectorAll('.skill-chip');
    const countEl = document.getElementById('skill-count');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const category = tab.getAttribute('data-category');
        let visibleCount = 0;

        chips.forEach(chip => {
          if (category === 'all' || chip.getAttribute('data-category') === category) {
            chip.classList.remove('hidden-skill');
            visibleCount++;
          } else {
            chip.classList.add('hidden-skill');
          }
        });

        if (countEl) {
          countEl.textContent = `Showing ${visibleCount} total skills`;
        }
      });
    });
  });
</script>
