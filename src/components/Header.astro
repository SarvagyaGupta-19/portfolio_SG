---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const hasCertifications = siteConfig.certifications && siteConfig.certifications.length > 0;
---

<!-- Header Navigation -->
<header
  id="header"
  class="fixed top-0 left-0 right-0 transition-all duration-500"
  style={`--accent-color: ${siteConfig.accentColor}; z-index: 9999;`}
>
  <nav class="max-w-7xl mx-auto px-6 py-4">
    <div class="flex items-center justify-center">
      <!-- Desktop Navigation - Centered -->
      <div class="hidden lg:flex items-center bg-white/80 backdrop-blur-xl rounded-full px-2 py-2 shadow-lg border border-gray-200/50">
        <a href="#about" class="nav-link" data-section="about">About</a>
        <a href="#skills" class="nav-link" data-section="skills">Skills</a>
        {hasProjects && <a href="#projects" class="nav-link" data-section="projects">Projects</a>}
        {hasExperience && <a href="#experience" class="nav-link" data-section="experience">Experience</a>}
        {hasCertifications && <a href="#certifications" class="nav-link" data-section="certifications">Certifications</a>}
        {hasEducation && <a href="#education" class="nav-link" data-section="education">Education</a>}
        <a 
          href="/resume.pdf"
          target="_blank"
          class="nav-link resume-link"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
          </svg>
          Resume
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden mobile-menu-button" aria-label="Toggle menu">
        <span class="menu-bar bar1"></span>
        <span class="menu-bar bar2"></span>
        <span class="menu-bar bar3"></span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Navigation Menu - Independent from header -->
<div id="mobile-menu" class="mobile-menu hidden">
  <div class="mobile-menu-overlay"></div>
  <div class="mobile-menu-content">
    <div class="mobile-menu-header">
      <div class="menu-header-top">
        <span class="menu-title">Menu</span>
        <button id="mobile-menu-close" class="menu-close-btn" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>
    <nav class="mobile-nav">
      <a href="#about" class="mobile-nav-link" data-section="about">
        <div class="link-content">
          <span class="link-number">01</span>
          <span class="link-text">About</span>
        </div>
        <svg class="link-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href="#skills" class="mobile-nav-link" data-section="skills">
        <div class="link-content">
          <span class="link-number">02</span>
          <span class="link-text">Skills</span>
        </div>
        <svg class="link-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      {hasProjects && <a href="#projects" class="mobile-nav-link" data-section="projects">
        <div class="link-content">
          <span class="link-number">03</span>
          <span class="link-text">Projects</span>
        </div>
        <svg class="link-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>}
      {hasExperience && <a href="#experience" class="mobile-nav-link" data-section="experience">
        <div class="link-content">
          <span class="link-number">04</span>
          <span class="link-text">Experience</span>
        </div>
        <svg class="link-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>}
      {hasCertifications && <a href="#certifications" class="mobile-nav-link" data-section="certifications">
        <div class="link-content">
          <span class="link-number">05</span>
          <span class="link-text">Certifications</span>
        </div>
        <svg class="link-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>}
      {hasEducation && <a href="#education" class="mobile-nav-link" data-section="education">
        <div class="link-content">
          <span class="link-number">06</span>
          <span class="link-text">Education</span>
        </div>
        <svg class="link-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>}
    </nav>
    <div class="mobile-menu-footer">
      <a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="mobile-resume-button">
        <svg class="resume-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span>Download Resume</span>
      </a>
    </div>
  </div>
</div>

<script>
  // Header scroll effect
  let lastScroll = 0;
  const header = document.getElementById("header");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileMenuClose = document.getElementById("mobile-menu-close");

  // Mobile menu toggle
  mobileMenuBtn?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    
    if (isOpen) {
      mobileMenu?.classList.add("closing");
      setTimeout(() => {
        mobileMenu?.classList.add("hidden");
        mobileMenu?.classList.remove("closing");
      }, 300);
      mobileMenuBtn?.classList.remove("active");
      document.body.classList.remove("overflow-hidden");
    } else {
      mobileMenu?.classList.remove("hidden");
      mobileMenuBtn?.classList.add("active");
      document.body.classList.add("overflow-hidden");
    }
  });

  // Close button
  mobileMenuClose?.addEventListener("click", (e) => {
    e.preventDefault();
    mobileMenu?.classList.add("closing");
    setTimeout(() => {
      mobileMenu?.classList.add("hidden");
      mobileMenu?.classList.remove("closing");
    }, 300);
    mobileMenuBtn?.classList.remove("active");
    document.body.classList.remove("overflow-hidden");
  });

  // Close mobile menu when clicking overlay
  document.querySelector(".mobile-menu-overlay")?.addEventListener("click", () => {
    mobileMenu?.classList.add("closing");
    setTimeout(() => {
      mobileMenu?.classList.add("hidden");
      mobileMenu?.classList.remove("closing");
    }, 300);
    mobileMenuBtn?.classList.remove("active");
    document.body.classList.remove("overflow-hidden");
  });

  // Close mobile menu when clicking a navigation link
  document.querySelectorAll(".mobile-nav-link").forEach(link => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("closing");
      setTimeout(() => {
        mobileMenu?.classList.add("hidden");
        mobileMenu?.classList.remove("closing");
      }, 300);
      mobileMenuBtn?.classList.remove("active");
      document.body.classList.remove("overflow-hidden");
    });
  });

  // Handle resume download button - close menu after short delay to allow download
  document.querySelector(".mobile-resume-button")?.addEventListener("click", () => {
    setTimeout(() => {
      mobileMenu?.classList.add("closing");
      setTimeout(() => {
        mobileMenu?.classList.add("hidden");
        mobileMenu?.classList.remove("closing");
      }, 300);
      mobileMenuBtn?.classList.remove("active");
      document.body.classList.remove("overflow-hidden");
    }, 100);
  });

  window.addEventListener("scroll", () => {
    const currentScroll = window.pageYOffset;
    
    // Add background when scrolled
    if (currentScroll > 20) {
      header?.classList.add("header-scrolled");
    } else {
      header?.classList.remove("header-scrolled");
    }
    
    lastScroll = currentScroll;

    // Active section highlighting
    const sections = document.querySelectorAll('section, div[id]');
    const navLinks = document.querySelectorAll('.nav-link, .mobile-nav-link');
    
    sections.forEach(section => {
      const sectionTop = section.offsetTop - 100;
      const sectionHeight = section.clientHeight;
      const sectionId = section.getAttribute('id');
      
      if (currentScroll >= sectionTop && currentScroll < sectionTop + sectionHeight) {
        navLinks.forEach(link => {
          link.classList.remove('active');
          if (link.getAttribute('data-section') === sectionId) {
            link.classList.add('active');
          }
        });
      }
    });
  });
</script>

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  :root {
    --accent-color: var(--accentColor);
  }

  /* Header Styles */
  #header {
    background: transparent;
  }

  #header.header-scrolled {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  /* Mobile Menu Button - Professional Elevated Style */
  .mobile-menu-button {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 48px;
    height: 48px;
    border: 2px solid #e5e7eb;
    background: #ffffff;
    cursor: pointer;
    padding: 0;
    position: relative;
    border-radius: 12px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    overflow: hidden;
  }

  .mobile-menu-button::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--accent-color), #3b7de8);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }

  .mobile-menu-button:hover {
    border-color: var(--accent-color);
    box-shadow: 0 4px 16px rgba(66, 133, 244, 0.25);
    transform: translateY(-2px);
  }

  .mobile-menu-button:hover::before {
    opacity: 1;
  }

  .mobile-menu-button:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px rgba(66, 133, 244, 0.2);
  }

  .menu-bar {
    width: 24px;
    height: 2.5px;
    background: #1f2937;
    border-radius: 3px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
    position: relative;
    z-index: 1;
  }

  .mobile-menu-button:hover .menu-bar {
    background: #ffffff;
  }

  .mobile-menu-button.active {
    border-color: var(--accent-color);
    box-shadow: 0 4px 16px rgba(66, 133, 244, 0.3);
  }

  .mobile-menu-button.active::before {
    opacity: 1;
  }

  .mobile-menu-button.active .bar1 {
    transform: translateY(8.5px) rotate(45deg);
    background: #ffffff;
  }

  .mobile-menu-button.active .bar2 {
    opacity: 0;
    transform: scaleX(0);
  }

  .mobile-menu-button.active .bar3 {
    transform: translateY(-8.5px) rotate(-45deg);
    background: #ffffff;
  }

  /* Mobile Menu - Premium Professional Design */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 10000;
    pointer-events: none;
  }

  .mobile-menu:not(.hidden) {
    pointer-events: auto;
  }

  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.4) 100%);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu:not(.hidden) .mobile-menu-overlay {
    opacity: 1;
  }

  .mobile-menu.closing .mobile-menu-overlay {
    opacity: 0;
  }

  .mobile-menu-content {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 90%;
    max-width: 420px;
    background: linear-gradient(180deg, #ffffff 0%, #fafbfc 100%);
    box-shadow: -12px 0 48px rgba(0, 0, 0, 0.15);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .mobile-menu:not(.hidden) .mobile-menu-content {
    transform: translateX(0);
  }

  .mobile-menu.closing .mobile-menu-content {
    transform: translateX(100%);
  }

  .mobile-menu-header {
    padding: 2rem;
    background: white;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .menu-header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .menu-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #1a1a1a;
    font-family: 'Inter', sans-serif;
  }

  .menu-close-btn {
    width: 44px;
    height: 44px;
    display: flex !important;
    align-items: center;
    justify-content: center;
    border: 2px solid #e5e7eb !important;
    background: #ffffff !important;
    border-radius: 12px;
    cursor: pointer !important;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
    padding: 0;
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
    position: relative;
    overflow: hidden;
  }

  .menu-close-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #ef4444, #dc2626);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 10px;
    z-index: 0;
  }

  .menu-close-btn:hover {
    border-color: #ef4444 !important;
    transform: scale(1.1) rotate(90deg);
    box-shadow: 0 4px 16px rgba(239, 68, 68, 0.35);
  }

  .menu-close-btn:hover::before {
    opacity: 1;
  }

  .menu-close-btn:active {
    transform: scale(0.95) rotate(90deg);
    box-shadow: 0 2px 8px rgba(239, 68, 68, 0.3);
  }

  .menu-close-btn svg {
    stroke: #1f2937 !important;
    stroke-width: 2.5 !important;
    width: 20px !important;
    height: 20px !important;
    display: block !important;
    opacity: 1 !important;
    visibility: visible !important;
    fill: none !important;
    position: relative;
    z-index: 1;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .menu-close-btn:hover svg {
    stroke: white !important;
    stroke-width: 3 !important;
  }

  .mobile-nav {
    flex: 1;
    padding: 1.5rem 0;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(66, 133, 244, 0.3) transparent;
  }

  .mobile-nav::-webkit-scrollbar {
    width: 4px;
  }

  .mobile-nav::-webkit-scrollbar-track {
    background: transparent;
  }

  .mobile-nav::-webkit-scrollbar-thumb {
    background: rgba(66, 133, 244, 0.3);
    border-radius: 2px;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    color: #1a1a1a;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .mobile-nav-link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--accent-color);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-nav-link::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, 
      rgba(66, 133, 244, 0.06) 0%, 
      rgba(66, 133, 244, 0.02) 100%);
    opacity: 0;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-nav-link:hover::before,
  .mobile-nav-link.active::before {
    transform: scaleX(1);
  }

  .mobile-nav-link:hover::after,
  .mobile-nav-link.active::after {
    opacity: 1;
  }

  .link-content {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .link-number {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent-color);
    font-family: 'IBM Plex Mono', monospace;
    opacity: 0.6;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-nav-link:hover .link-number,
  .mobile-nav-link.active .link-number {
    opacity: 1;
    transform: translateX(4px);
  }

  .link-text {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-nav-link:hover .link-text,
  .mobile-nav-link.active .link-text {
    color: var(--accent-color);
    transform: translateX(4px);
  }

  .link-icon {
    position: relative;
    z-index: 1;
    stroke: #9ca3af;
    flex-shrink: 0;
    opacity: 1;
    transform: translateX(0);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: block;
  }

  .mobile-nav-link:hover .link-icon {
    opacity: 1;
    transform: translateX(4px);
    stroke: var(--accent-color);
  }

  .mobile-menu-footer {
    padding: 2rem;
    background: white;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.04);
  }

  .mobile-resume-button {
    display: flex !important;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1.25rem 1.5rem !important;
    background: #4285f4 !important;
    color: #ffffff !important;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0;
    text-decoration: none;
    border-radius: 10px;
    transition: all 0.25s ease;
    box-shadow: 0 4px 16px rgba(66, 133, 244, 0.4) !important;
    border: none !important;
    cursor: pointer !important;
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
  }

  .mobile-resume-button svg {
    width: 22px !important;
    height: 22px !important;
    stroke-width: 2.5 !important;
    stroke: #ffffff !important;
    fill: none !important;
    flex-shrink: 0;
    display: block !important;
    opacity: 1 !important;
    visibility: visible !important;
  }

  .mobile-resume-button span {
    font-weight: 700;
    color: #ffffff !important;
    opacity: 1 !important;
    visibility: visible !important;
  }

  .mobile-resume-button:hover {
    background: #3b7de8 !important;
    box-shadow: 0 6px 20px rgba(66, 133, 244, 0.5) !important;
    transform: translateY(-2px);
  }

  .mobile-resume-button:active {
    transform: translateY(0);
  }

  .mobile-resume-button:hover .resume-icon {
    animation: downloadPulse 0.8s ease infinite;
  }

  @keyframes downloadPulse {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(3px);
    }
  }

  /* Navigation Links */
  .nav-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    color: #4b5563;
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    border-radius: 999px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover {
    color: var(--accent-color);
    background: rgba(66, 133, 244, 0.08);
  }

  .nav-link.active {
    color: white;
    background: var(--accent-color);
    box-shadow: 0 4px 12px rgba(66, 133, 244, 0.3);
  }

  .nav-link.resume-link {
    background: var(--accent-color);
    color: white;
    font-weight: 600;
    box-shadow: 0 1px 3px rgba(66, 133, 244, 0.2);
  }

  .nav-link.resume-link:hover {
    background: #3b7de8;
    box-shadow: 0 4px 12px rgba(66, 133, 244, 0.3);
    transform: translateY(-1px);
  }

  .nav-link.resume-link:active {
    transform: translateY(0);
  }

  .nav-link.resume-link svg {
    transition: transform 0.25s cubic-bezier(0.645, 0.045, 0.355, 1);
  }

  .nav-link.resume-link:hover svg {
    transform: translateY(-1px);
  }
</style>
