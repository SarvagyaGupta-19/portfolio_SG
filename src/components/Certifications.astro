---
import { siteConfig } from "../config";

const hasCertifications = siteConfig.certifications && siteConfig.certifications.length > 0;

// Helper function to get platform icon - now supports custom logo paths
function getPlatformIcon(cert: any) {
  // If certificate has a custom logo path, use it
  if (cert.logo) {
    return `<img src="${cert.logo}" alt="${cert.issuer} logo" class="h-14 w-14 object-contain rounded-lg p-1.5 bg-gray-50 border border-gray-100" />`;
  }
  
  // Fallback to SVG icons for known platforms
  const lowerIssuer = cert.issuer.toLowerCase();
  
  // AWS
  if (lowerIssuer.includes('aws') || lowerIssuer.includes('amazon')) {
    return '<svg class="h-14 w-14 p-2 bg-gray-50 rounded-lg border border-gray-100" viewBox="0 0 24 24" fill="#FF9900"><path d="M6.763 10.036c0 .296.032.535.088.71.064.176.144.368.256.576.04.063.056.127.056.183 0 .08-.048.16-.144.24l-.479.319c-.068.048-.136.071-.192.071-.08 0-.16-.04-.239-.112-.112-.12-.208-.248-.287-.384-.08-.135-.16-.296-.256-.488-.645.76-1.455 1.14-2.43 1.14-.695 0-1.247-.199-1.655-.597-.408-.397-.615-.925-.615-1.582 0-.7.248-1.267.744-1.702.496-.435 1.156-.65 1.983-.65.272 0 .551.024.848.064.296.04.6.104.927.16v-.528c0-.545-.112-.925-.336-1.15-.232-.224-.624-.336-1.183-.336-.256 0-.52.032-.792.088-.272.056-.536.12-.792.208-.12.04-.208.064-.256.072-.048.008-.08.008-.104.008-.104 0-.16-.08-.16-.232v-.368c0-.12.016-.208.056-.264.04-.056.12-.104.239-.16.272-.144.6-.263.983-.368.384-.104.792-.16 1.224-.16.935 0 1.62.215 2.064.64.44.432.66 1.08.66 1.952v2.56zm-3.348 1.255c.264 0 .536-.048.824-.143.287-.096.543-.271.767-.511.136-.16.232-.336.288-.535.056-.2.088-.448.088-.744v-.359c-.231-.04-.48-.072-.735-.096-.256-.023-.512-.04-.76-.04-.543 0-.943.104-1.215.32-.272.215-.407.527-.407.943 0 .384.095.672.288.872.192.191.48.287.863.287zm6.66.911c-.136 0-.224-.024-.28-.08-.056-.048-.104-.16-.152-.311L7.583 3.98c-.048-.16-.072-.264-.072-.32 0-.128.064-.2.192-.2h.783c.144 0 .24.024.288.08.056.048.096.16.144.311l1.807 7.12 1.679-7.12c.04-.16.088-.264.136-.311.056-.048.152-.08.296-.08h.639c.144 0 .24.024.296.08.056.048.104.16.136.311l1.695 7.207 1.863-7.207c.048-.16.096-.264.144-.311.056-.048.152-.08.287-.08h.743c.128 0 .2.064.2.2 0 .04-.008.088-.016.143-.008.056-.024.12-.048.192L15.575 11.8c-.048.16-.096.264-.152.312-.056.047-.144.08-.28.08h-.687c-.144 0-.24-.024-.296-.08-.056-.056-.104-.16-.136-.32l-1.671-6.96-1.655 6.952c-.04.16-.088.264-.136.32-.056.056-.152.08-.296.08h-.687zm10.703.232c-.431 0-.863-.048-1.279-.144-.416-.096-.735-.2-.927-.32-.12-.08-.2-.168-.232-.256-.032-.088-.048-.184-.048-.28v-.383c0-.152.056-.232.16-.232.04 0 .08.008.12.016.04.008.104.032.168.056.231.104.48.184.743.248.264.056.527.088.791.088.416 0 .735-.072.959-.224.224-.152.344-.368.344-.647 0-.192-.064-.36-.192-.495-.128-.136-.368-.264-.735-.384l-1.055-.328c-.528-.16-.919-.4-1.167-.704-.248-.304-.368-.64-.368-1.008 0-.296.064-.56.184-.791.12-.232.287-.431.504-.583.216-.16.48-.271.791-.36.312-.088.647-.128.999-.128.183 0 .375.008.559.032.191.024.367.056.535.088.16.04.312.08.455.127.144.048.256.096.336.144.104.064.184.128.232.2.048.064.072.16.072.271v.36c0 .152-.056.232-.16.232-.064 0-.168-.032-.296-.096-.479-.216-1.015-.32-1.607-.32-.375 0-.671.064-.88.191-.207.128-.312.328-.312.6 0 .192.072.36.216.504.144.144.408.288.792.424l1.031.319c.52.16.903.384 1.143.68.24.296.36.647.36 1.047 0 .304-.064.583-.191.831-.128.248-.304.463-.528.647-.224.184-.496.32-.815.416-.336.096-.695.144-1.087.144z"/></svg>';
  }
  
  // Generic certificate icon for others
  return '<svg class="h-14 w-14 p-2 bg-gray-50 text-gray-500 rounded-lg border border-gray-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>';
}
---

{hasCertifications && (
  <section id="certifications" class="w-full bg-gradient-to-b from-white via-blue-50/20 to-white">
    <div class="container mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="mb-16 text-center scroll-reveal">
        <h2 class="mb-6 text-4xl font-bold text-gray-900 md:text-5xl leading-tight">
          Professional <span class="text-[var(--accent-color)]">Certifications</span>
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-gray-600" style="line-height: 1.8;">
          Industry-recognized certifications in Artificial Intelligence/Machine Learning.
        </p>
        <div class="mt-4 flex items-center justify-center gap-2 text-sm text-gray-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M13.8 12H3"></path>
          </svg>
          <span>Click any certificate card to view details</span>
        </div>
      </div>

      <!-- Certifications Grid -->
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
        {siteConfig.certifications.map((cert, index) => (
          <a 
            href={cert.link} 
            target="_blank" 
            rel="noopener noreferrer"
            class={`scroll-reveal scroll-reveal-delay-${(index % 6) + 1} group relative block overflow-hidden rounded-xl bg-white p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl border border-gray-200 cursor-pointer`}
          >
            {/* Accent Border Left */}
            <div class="absolute left-0 top-0 h-full w-1 bg-gradient-to-b from-[#4285f4] via-[#ea4335] via-[#fbbc04] to-[#34a853] transition-all duration-300 group-hover:w-1.5"></div>
            
            {/* Card Content Container */}
            <div class="flex gap-4">
              {/* Logo on Left */}
              <div class="flex-shrink-0" set:html={getPlatformIcon(cert)}></div>
              
              {/* Certificate Info on Right */}
              <div class="flex-1 min-w-0 space-y-3">
                {/* Certificate Name */}
                <h3 class="text-lg font-bold text-gray-900 leading-tight group-hover:text-[#4285f4] transition-colors line-clamp-2">
                  {cert.name}
                </h3>

                {/* Issuer */}
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                  </svg>
                  <span class="font-medium truncate">{cert.issuer}</span>
                </div>

                {/* Date */}
                <div class="flex items-center gap-2 text-sm text-gray-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  <span class="truncate">{cert.date}</span>
                </div>


              </div>
            </div>

            {/* View Certificate Indicator */}
            <div class="mt-4 flex items-center justify-between pt-3 border-t border-gray-100">
              <span class="text-xs font-semibold text-gray-600 group-hover:text-[#4285f4] transition-colors">
                View Certificate
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400 group-hover:text-[#4285f4] group-hover:translate-x-1 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"></path>
              </svg>
            </div>

            {/* Hover Shine Effect */}
            <div class="absolute inset-0 -z-10 bg-gradient-to-br from-blue-50/50 via-transparent to-indigo-50/50 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            
            {/* Click Ripple Indicator */}
            <div class="absolute top-2 right-2 h-2 w-2 rounded-full bg-[#34a853] opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <span class="absolute inset-0 animate-ping rounded-full bg-[#34a853] opacity-75"></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  :root {
    --accent-color: var(--accentColor);
  }
</style>
