---
import { siteConfig } from "../config";

const hasCertifications = siteConfig.certifications && siteConfig.certifications.length > 0;

// Helper function to get platform icon
function getPlatformIcon(issuer: string) {
  const lowerIssuer = issuer.toLowerCase();
  
  // AWS
  if (lowerIssuer.includes('aws') || lowerIssuer.includes('amazon')) {
    return '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="#FF9900"><path d="M6.763 10.036c0 .296.032.535.088.71.064.176.144.368.256.576.04.063.056.127.056.183 0 .08-.048.16-.144.24l-.479.319c-.068.048-.136.071-.192.071-.08 0-.16-.04-.239-.112-.112-.12-.208-.248-.287-.384-.08-.135-.16-.296-.256-.488-.645.76-1.455 1.14-2.43 1.14-.695 0-1.247-.199-1.655-.597-.408-.397-.615-.925-.615-1.582 0-.7.248-1.267.744-1.702.496-.435 1.156-.65 1.983-.65.272 0 .551.024.848.064.296.04.6.104.927.16v-.528c0-.545-.112-.925-.336-1.15-.232-.224-.624-.336-1.183-.336-.256 0-.52.032-.792.088-.272.056-.536.12-.792.208-.12.04-.208.064-.256.072-.048.008-.08.008-.104.008-.104 0-.16-.08-.16-.232v-.368c0-.12.016-.208.056-.264.04-.056.12-.104.239-.16.272-.144.6-.263.983-.368.384-.104.792-.16 1.224-.16.935 0 1.62.215 2.064.64.44.432.66 1.08.66 1.952v2.56zm-3.348 1.255c.264 0 .536-.048.824-.143.287-.096.543-.271.767-.511.136-.16.232-.336.288-.535.056-.2.088-.448.088-.744v-.359c-.231-.04-.48-.072-.735-.096-.256-.023-.512-.04-.76-.04-.543 0-.943.104-1.215.32-.272.215-.407.527-.407.943 0 .384.095.672.288.872.192.191.48.287.863.287zm6.66.911c-.136 0-.224-.024-.28-.08-.056-.048-.104-.16-.152-.311L7.583 3.98c-.048-.16-.072-.264-.072-.32 0-.128.064-.2.192-.2h.783c.144 0 .24.024.288.08.056.048.096.16.144.311l1.807 7.12 1.679-7.12c.04-.16.088-.264.136-.311.056-.048.152-.08.296-.08h.639c.144 0 .24.024.296.08.056.048.104.16.136.311l1.695 7.207 1.863-7.207c.048-.16.096-.264.144-.311.056-.048.152-.08.287-.08h.743c.128 0 .2.064.2.2 0 .04-.008.088-.016.143-.008.056-.024.12-.048.192L15.575 11.8c-.048.16-.096.264-.152.312-.056.047-.144.08-.28.08h-.687c-.144 0-.24-.024-.296-.08-.056-.056-.104-.16-.136-.32l-1.671-6.96-1.655 6.952c-.04.16-.088.264-.136.32-.056.056-.152.08-.296.08h-.687zm10.703.232c-.431 0-.863-.048-1.279-.144-.416-.096-.735-.2-.927-.32-.12-.08-.2-.168-.232-.256-.032-.088-.048-.184-.048-.28v-.383c0-.152.056-.232.16-.232.04 0 .08.008.12.016.04.008.104.032.168.056.231.104.48.184.743.248.264.056.527.088.791.088.416 0 .735-.072.959-.224.224-.152.344-.368.344-.647 0-.192-.064-.36-.192-.495-.128-.136-.368-.264-.735-.384l-1.055-.328c-.528-.16-.919-.4-1.167-.704-.248-.304-.368-.64-.368-1.008 0-.296.064-.56.184-.791.12-.232.287-.431.504-.583.216-.16.48-.271.791-.36.312-.088.647-.128.999-.128.183 0 .375.008.559.032.191.024.367.056.535.088.16.04.312.08.455.127.144.048.256.096.336.144.104.064.184.128.232.2.048.064.072.16.072.271v.36c0 .152-.056.232-.16.232-.064 0-.168-.032-.296-.096-.479-.216-1.015-.32-1.607-.32-.375 0-.671.064-.88.191-.207.128-.312.328-.312.6 0 .192.072.36.216.504.144.144.408.288.792.424l1.031.319c.52.16.903.384 1.143.68.24.296.36.647.36 1.047 0 .304-.064.583-.191.831-.128.248-.304.463-.528.647-.224.184-.496.32-.815.416-.336.096-.695.144-1.087.144z"/></svg>';
  }
  
  // Google Cloud
  if (lowerIssuer.includes('google')) {
    return '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="#4285F4"><path d="M12.19 2.38a9.344 9.344 0 0 0-9.234 6.893c.053-.02-.055.013 0 0-2.156 3.985-.24 8.942 3.7 10.97 3.94 2.028 8.99.68 11.255-3.124 2.265-3.804 1.447-8.68-1.867-11.31-.524-.42-1.05-.83-1.655-1.16a9.344 9.344 0 0 0-2.199-.269zm-.08 3.562a5.823 5.823 0 0 1 4.052 1.483 5.813 5.813 0 0 1 1.91 4.44v.23c0 1.544.58 2.853 1.524 3.776.944.924 2.246 1.375 3.776 1.375h.157v1.938h-5.478c-1.544 0-2.853-.58-3.776-1.524-.924-.943-1.375-2.246-1.375-3.775V8.375c0-1.215.446-2.284 1.21-3.07z"/></svg>';
  }
  
  // Azure/Microsoft
  if (lowerIssuer.includes('azure') || lowerIssuer.includes('microsoft')) {
    return '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="#0078D4"><path d="M22.379 23.343a1.62 1.62 0 0 0 1.536-2.14v.002L17.35 1.76A1.62 1.62 0 0 0 15.816.657H8.184A1.62 1.62 0 0 0 6.65 1.76L.086 21.204a1.62 1.62 0 0 0 1.536 2.139h4.741a1.62 1.62 0 0 0 1.535-1.103l.977-2.892 4.947 3.675c.28.208.618.32.966.32h7.591z"/></svg>';
  }
  
  // Coursera
  if (lowerIssuer.includes('coursera')) {
    return '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="#0056D2"><path d="M23.49 13.53c0 5.7-4.65 10.35-10.35 10.35-2.93 0-5.58-1.22-7.47-3.18l2.15-2.15c1.41 1.39 3.36 2.25 5.52 2.25 4.28 0 7.75-3.47 7.75-7.75s-3.47-7.75-7.75-7.75c-2.16 0-4.11.86-5.52 2.25L5.67 5.4c1.89-1.96 4.54-3.18 7.47-3.18 5.7 0 10.35 4.65 10.35 10.35zm-10.35-6.1c3.36 0 6.1 2.74 6.1 6.1 0 3.36-2.74 6.1-6.1 6.1-1.7 0-3.25-.7-4.36-1.82l2.15-2.15c.63.63 1.51 1.02 2.47 1.02 1.93 0 3.5-1.57 3.5-3.5s-1.57-3.5-3.5-3.5c-.96 0-1.84.39-2.47 1.02L8.78 8.25c1.11-1.12 2.66-1.82 4.36-1.82z"/></svg>';
  }
  
  // Generic certificate icon for others
  return '<svg class="h-6 w-6 text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15V3m0 12l-4-4m4 4l4-4m-4 4v12"/><path d="M2 17l4 4 4-4"/><path d="M22 17l-4 4-4-4"/><circle cx="12" cy="12" r="10"/></svg>';
}
---

{hasCertifications && (
  <div id="certifications" class="w-full bg-gradient-to-b from-white via-yellow-50/20 to-white py-24">
    <div class="container mx-auto max-w-7xl px-6">
      <!-- Section Header -->
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-4xl font-bold text-gray-900 md:text-5xl">
          Professional <span class="text-[var(--accent-color)]">Certifications</span>
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-gray-600 leading-relaxed">
          Industry-recognized certifications demonstrating expertise in cloud computing, machine learning, and software development
        </p>
      </div>

      <!-- Certifications Grid -->
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {siteConfig.certifications.map((cert) => (
          <div class="group relative overflow-hidden rounded-2xl bg-white p-6 shadow-md transition-all duration-300 hover:-translate-y-2 hover:shadow-xl border border-gray-200">
            {/* Accent Border Top */}
            <div class="absolute left-0 top-0 h-1 w-full bg-gradient-to-r from-[#4285f4] via-[#ea4335] via-[#fbbc04] to-[#34a853]"></div>
            
            {/* Platform Icon */}
            <div class="mb-4" set:html={getPlatformIcon(cert.issuer)}></div>
            
            {/* Certification Content */}
            <div class="space-y-4">
              <h3 class="text-xl font-bold text-gray-900 leading-tight">
                {cert.name}
              </h3>

              <div class="flex items-center gap-2 text-sm text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                  <circle cx="12" cy="7" r="4"></circle>
                </svg>
                <span class="font-medium">{cert.issuer}</span>
              </div>

              <div class="flex items-center gap-2 text-sm text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="16" y1="2" x2="16" y2="6"></line>
                  <line x1="8" y1="2" x2="8" y2="6"></line>
                  <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                <span>{cert.date}</span>
              </div>

              {cert.credentialId && (
                <div class="rounded-lg bg-gray-50 px-3 py-2 text-xs font-mono text-gray-700">
                  ID: {cert.credentialId}
                </div>
              )}

              {/* See Certificate Button */}
              {cert.link && (
                <a 
                  href={cert.link} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center gap-2 rounded-lg bg-[var(--accent-color)] px-4 py-2.5 text-sm font-semibold text-white transition-all duration-200 hover:bg-[var(--accent-color)]/90 hover:shadow-lg hover:shadow-[var(--accent-color)]/30"
                >
                  <span>View Certificate</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </a>
              )}
            </div>

            {/* Subtle Hover Gradient */}
            <div class="absolute inset-0 -z-10 bg-gradient-to-br from-[var(--accent-color)]/5 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
)}

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  :root {
    --accent-color: var(--accentColor);
  }
</style>
