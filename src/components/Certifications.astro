---
import { siteConfig } from "../config";

const hasCertifications = siteConfig.certifications && siteConfig.certifications.length > 0;
---

{hasCertifications && (
  <div id="certifications" class="w-full bg-gradient-to-b from-white to-gray-50 py-24">
    <div class="container mx-auto max-w-7xl px-6">
      <!-- Section Header -->
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-4xl font-bold text-gray-900 md:text-5xl">
          Professional <span class="text-[var(--accent-color)]">Certifications</span>
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-gray-600">
          Industry-recognized certifications demonstrating expertise in cloud computing, machine learning, and software development
        </p>
      </div>

      <!-- Certifications Grid -->
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {siteConfig.certifications.map((cert) => (
          <div class="group relative overflow-hidden rounded-2xl bg-white p-6 shadow-lg transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl border border-gray-100">
            {/* Accent Border Top */}
            <div class="absolute left-0 top-0 h-1 w-full bg-gradient-to-r from-[var(--accent-color)] to-[#ea4335]"></div>
            
            {/* Certification Content */}
            <div class="space-y-4">
              <div class="flex items-start justify-between">
                <h3 class="text-xl font-bold text-gray-900 pr-2 leading-tight">
                  {cert.name}
                </h3>
                {cert.link && (
                  <a 
                    href={cert.link} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="flex-shrink-0 text-[var(--accent-color)] opacity-0 transition-opacity group-hover:opacity-100"
                    aria-label="View certificate"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                      <polyline points="15 3 21 3 21 9"></polyline>
                      <line x1="10" y1="14" x2="21" y2="3"></line>
                    </svg>
                  </a>
                )}
              </div>

              <div class="flex items-center gap-2 text-sm text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                  <circle cx="12" cy="7" r="4"></circle>
                </svg>
                <span class="font-medium">{cert.issuer}</span>
              </div>

              <div class="flex items-center gap-2 text-sm text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="16" y1="2" x2="16" y2="6"></line>
                  <line x1="8" y1="2" x2="8" y2="6"></line>
                  <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                <span>{cert.date}</span>
              </div>

              {cert.credentialId && (
                <div class="mt-4 rounded-lg bg-gray-50 px-3 py-2 text-xs font-mono text-gray-700">
                  ID: {cert.credentialId}
                </div>
              )}
            </div>

            {/* Hover Effect Gradient */}
            <div class="absolute inset-0 -z-10 bg-gradient-to-br from-[var(--accent-color)]/5 to-[#34a853]/5 opacity-0 transition-opacity group-hover:opacity-100"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
)}

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  :root {
    --accent-color: var(--accentColor);
  }
</style>
