---
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-white py-24 md:h-screen"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 -z-10"
    style={`background: radial-gradient(ellipse 800px 1200px at 0% 0%, ${siteConfig.accentColor}40 0%, ${siteConfig.accentColor}25 20%, ${siteConfig.accentColor}10 40%, rgba(255, 255, 255, 0.3) 70%, rgba(255, 255, 255, 0.8) 90%, white 100%)`}
  >
  </div>
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
  >
    <defs>
      <pattern
        x="50%"
        y={-1}
        id="0787a7c5-978c-4f66-83c7-11c213f99cb7"
        width={200}
        height={200}
        patternUnits="userSpaceOnUse"
      >
        <path d="M.5 200V.5H200" fill="none"></path>
      </pattern>
      <pattern
        id="programming-symbols"
        x="0"
        y="0"
        width="500"
        height="500"
        patternUnits="userSpaceOnUse"
      >
        <!-- ML Equations and Formulas -->
        <text
          x="50"
          y="50"
          fill={siteConfig.accentColor}
          font-family="'Times New Roman', serif"
          font-size="24"
          font-style="italic"
          opacity="0.62"
          transform="rotate(-12)">∂L/∂θ</text
        >
        <text
          x="180"
          y="80"
          fill="#34a853"
          font-family="'Times New Roman', serif"
          font-size="22"
          opacity="0.6"
          transform="rotate(8)">∇f(x)</text
        >
        <text
          x="320"
          y="60"
          fill="#ea4335"
          font-family="'Times New Roman', serif"
          font-size="26"
          font-style="italic"
          opacity="0.64"
          transform="rotate(-5)">σ(z)</text
        >
        <text
          x="80"
          y="150"
          fill="#fbbc04"
          font-family="'Times New Roman', serif"
          font-size="16"
          opacity="0.58"
          transform="rotate(15)">E[X]</text
        >
        <text
          x="250"
          y="140"
          fill={siteConfig.accentColor}
          font-family="'Times New Roman', serif"
          font-size="19"
          opacity="0.62"
          transform="rotate(-8)">Σw·x</text
        >
        <text
          x="400"
          y="130"
          fill="#34a853"
          font-family="'Times New Roman', serif"
          font-size="17"
          font-style="italic"
          opacity="0.6"
          transform="rotate(10)">ReLU</text
        >
        <text
          x="120"
          y="240"
          fill="#ea4335"
          font-family="'Times New Roman', serif"
          font-size="21"
          opacity="0.62"
          transform="rotate(-10)">∫f(x)dx</text
        >
        <text
          x="320"
          y="220"
          fill={siteConfig.accentColor}
          font-family="'Times New Roman', serif"
          font-size="18"
          font-style="italic"
          opacity="0.6"
          transform="rotate(12)">α·∇θ</text
        >
        <text
          x="450"
          y="240"
          fill="#fbbc04"
          font-family="'Times New Roman', serif"
          font-size="16"
          opacity="0.59"
          transform="rotate(-7)">log(p)</text
        >
        <text
          x="60"
          y="330"
          fill="#34a853"
          font-family="'Times New Roman', serif"
          font-size="20"
          opacity="0.61"
          transform="rotate(9)">∑ᵢ xᵢ</text
        >
        <text
          x="220"
          y="350"
          fill="#ea4335"
          font-family="'Times New Roman', serif"
          font-size="17"
          font-style="italic"
          opacity="0.6"
          transform="rotate(-14)">softmax</text
        >
        <text
          x="380"
          y="340"
          fill={siteConfig.accentColor}
          font-family="'Times New Roman', serif"
          font-size="19"
          opacity="0.63"
          transform="rotate(6)">W·X+b</text
        >
        <text
          x="140"
          y="440"
          fill="#fbbc04"
          font-family="'Times New Roman', serif"
          font-size="18"
          font-style="italic"
          opacity="0.61"
          transform="rotate(-11)">||x||₂</text
        >
        <text
          x="300"
          y="460"
          fill="#34a853"
          font-family="'Times New Roman', serif"
          font-size="16"
          opacity="0.59"
          transform="rotate(13)">tanh(x)</text
        >
        <text
          x="440"
          y="450"
          fill="#ea4335"
          font-family="'Times New Roman', serif"
          font-size="20"
          opacity="0.62"
          transform="rotate(-9)">λ·||θ||</text
        >
        <!-- Small mathematical symbols scattered -->
        <circle cx="360" cy="100" r="2" fill={siteConfig.accentColor} opacity="0.55"/>
        <circle cx="150" cy="190" r="2" fill="#34a853" opacity="0.55"/>
        <circle cx="280" cy="310" r="2" fill="#ea4335" opacity="0.55"/>
        <circle cx="90" cy="400" r="2" fill="#fbbc04" opacity="0.55"/>
        <!-- Graph-like elements -->
        <path d="M 10 100 Q 40 80 70 100 T 130 100" stroke={siteConfig.accentColor} stroke-width="2" fill="none" opacity="0.5"/>
        <path d="M 350 300 Q 380 280 410 300 T 470 300" stroke="#34a853" stroke-width="2" fill="none" opacity="0.5"/>
        <path d="M 200 400 L 230 380 L 260 390 L 290 370" stroke="#ea4335" stroke-width="2" fill="none" opacity="0.5"/>
      </pattern>
    </defs>
    <rect
      fill="url(#programming-symbols)"
      width="100%"
      height="100%"
      opacity="0.9"></rect>
    <rect
      fill="url(#0787a7c5-978c-4f66-83c7-11c213f99cb7)"
      width="100%"
      height="100%"
      stroke-width={0}></rect>
  </svg>
  <div class="h-full mx-auto p-8 sm:p-12 md:p-24 flex items-center">
    <div>
      <h2
        class="text-pretty text-xl sm:text-2xl md:text-5xl font-bold tracking-tight text-gray-700 animate-fade-in"
      >
        Hello! 👋
      </h2>
      <h1
        class="mt-6 sm:mt-8 md:mt-10 text-pretty text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-bold tracking-tight text-gray-800 animate-fade-in animation-delay-200"
      >
        I'm <span style={{ color: siteConfig.accentColor }} id="name-text"
          >{siteConfig.name}</span
        >
      </h1>
      <p
        class="mt-4 sm:mt-6 md:mt-8 text-pretty text-base sm:text-lg md:text-xl/8 font-medium text-gray-600"
      >
        <span id="typing-text" class="typing-animation"></span><span class="cursor-blink">|</span>
      </p>
      
      <!-- Social Icons -->
      <div class="mt-6 flex gap-4 animate-fade-in animation-delay-400">
        {siteConfig.social?.email && (
          <a
            href={`mailto:${siteConfig.social.email}`}
            aria-label="Email"
            class="social-icon group"
          >
            <div class="icon-container">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
          </a>
        )}
        {siteConfig.social?.linkedin && (
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="social-icon group"
          >
            <div class="icon-container">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon-svg">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
          </a>
        )}
        {siteConfig.social?.twitter && (
          <a
            href={siteConfig.social.twitter}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X (Twitter)"
            class="social-icon group"
          >
            <div class="icon-container">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon-svg">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </div>
          </a>
        )}
        {siteConfig.social?.github && (
          <a
            href={siteConfig.social.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="social-icon group"
          >
            <div class="icon-container">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon-svg">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
          </a>
        )}
      </div>
      
      <!-- AI/ML Focus Badge -->
      <div class="mt-6 sm:mt-8 flex flex-wrap gap-3 animate-fade-in animation-delay-600">
        <span class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-blue-50 via-blue-100 to-blue-50 px-4 py-2 text-sm font-medium text-[#4285f4] border border-[#4285f4]/30 transition-all duration-500 hover:shadow-lg hover:shadow-[#4285f4]/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
          </svg>
          LLMs & RAG
        </span>
        <span class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-red-50 via-red-100 to-red-50 px-4 py-2 text-sm font-medium text-[#ea4335] border border-[#ea4335]/30 transition-all duration-500 hover:shadow-lg hover:shadow-[#ea4335]/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"></rect>
            <rect x="14" y="3" width="7" height="7"></rect>
            <rect x="14" y="14" width="7" height="7"></rect>
            <rect x="3" y="14" width="7" height="7"></rect>
          </svg>
          Computer Vision
        </span>
        <span class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-green-50 via-green-100 to-green-50 px-4 py-2 text-sm font-medium text-[#34a853] border border-[#34a853]/30 transition-all duration-500 hover:shadow-lg hover:shadow-[#34a853]/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
          </svg>
          Agentic AI
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }

  .animation-delay-400 {
    animation-delay: 0.4s;
  }

  .animation-delay-600 {
    animation-delay: 0.6s;
  }

  /* Social icon hover effects with glassmorphic blend */
  .social-icon {
    display: inline-block;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .icon-container {
    position: relative;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #000000;
    border-radius: 8px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .social-icon:hover .icon-container {
    transform: translateY(-3px);
    border-color: #333333;
  }

  .icon-svg {
    position: relative;
    z-index: 1;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .social-icon:hover .icon-svg {
    transform: scale(1.15);
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.15));
  }

  /* Email icon - Gmail red */
  .social-icon:nth-child(1) .icon-svg {
    color: #ea4335;
  }

  /* LinkedIn icon - LinkedIn blue */
  .social-icon:nth-child(2) .icon-svg {
    color: #0077b5;
  }

  /* X (Twitter) icon - Black */
  .social-icon:nth-child(3) .icon-svg {
    color: #000000;
  }

  /* GitHub icon - GitHub black */
  .social-icon:nth-child(4) .icon-svg {
    color: #181717;
  }

  .typing-animation {
    display: inline-block;
    min-height: 1.5em;
  }

  .cursor-blink {
    display: inline-block;
    animation: blink 1s step-end infinite;
    color: var(--accent-color);
    font-weight: bold;
    margin-left: 2px;
  }

  @keyframes blink {
    0%, 50% {
      opacity: 1;
    }
    51%, 100% {
      opacity: 0;
    }
  }
</style>

<script define:vars={{ title: siteConfig.title }}>
  // Typing animation
  function initTyping() {
    const typingElement = document.getElementById('typing-text');
    if (!typingElement) {
      // Retry if element not found
      setTimeout(initTyping, 100);
      return;
    }

    const texts = [
      title,
      'Building AI Systems',
      'LLMs & RAG',
      'Computer Vision',
      'Experience in AI-Frameworks'
    ];
    
    let textIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    let typeSpeed = 100;

    function typeText() {
      const currentText = texts[textIndex];
      
      if (!isDeleting) {
        typingElement.textContent = currentText.substring(0, charIndex + 1);
        charIndex++;
        
        if (charIndex === currentText.length) {
          isDeleting = true;
          typeSpeed = 2000; // Pause at end
        } else {
          typeSpeed = 100;
        }
      } else {
        typingElement.textContent = currentText.substring(0, charIndex - 1);
        charIndex--;
        
        if (charIndex === 0) {
          isDeleting = false;
          textIndex = (textIndex + 1) % texts.length;
          typeSpeed = 500; // Pause before next text
        } else {
          typeSpeed = 50;
        }
      }
      
      setTimeout(typeText, typeSpeed);
    }

    // Start typing immediately
    typeText();
  }

  // Start when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTyping);
  } else {
    initTyping();
  }
</script>
