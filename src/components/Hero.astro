---
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-white py-24 md:h-screen"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 -z-10"
    style={`background: radial-gradient(ellipse 800px 1200px at 0% 0%, ${siteConfig.accentColor}40 0%, ${siteConfig.accentColor}25 20%, ${siteConfig.accentColor}10 40%, rgba(255, 255, 255, 0.3) 70%, rgba(255, 255, 255, 0.8) 90%, white 100%)`}
  >
  </div>
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
  >
    <defs>
      <pattern
        x="50%"
        y={-1}
        id="0787a7c5-978c-4f66-83c7-11c213f99cb7"
        width={200}
        height={200}
        patternUnits="userSpaceOnUse"
      >
        <path d="M.5 200V.5H200" fill="none"></path>
      </pattern>
      <pattern
        id="programming-symbols"
        x="0"
        y="0"
        width="500"
        height="500"
        patternUnits="userSpaceOnUse"
      >
        <!-- ML Equations and Formulas -->
        <text
          x="50"
          y="50"
          fill={siteConfig.accentColor}
          font-family="'Times New Roman', serif"
          font-size="24"
          font-style="italic"
          opacity="0.62"
          transform="rotate(-12)">∂L/∂θ</text
        >
        <text
          x="180"
          y="80"
          fill="#34a853"
          font-family="'Times New Roman', serif"
          font-size="22"
          opacity="0.6"
          transform="rotate(8)">∇f(x)</text
        >
        <text
          x="320"
          y="60"
          fill="#ea4335"
          font-family="'Times New Roman', serif"
          font-size="26"
          font-style="italic"
          opacity="0.64"
          transform="rotate(-5)">σ(z)</text
        >
        <text
          x="80"
          y="150"
          fill="#fbbc04"
          font-family="'Times New Roman', serif"
          font-size="16"
          opacity="0.58"
          transform="rotate(15)">E[X]</text
        >
        <text
          x="250"
          y="140"
          fill={siteConfig.accentColor}
          font-family="'Times New Roman', serif"
          font-size="19"
          opacity="0.62"
          transform="rotate(-8)">Σw·x</text
        >
        <text
          x="400"
          y="130"
          fill="#34a853"
          font-family="'Times New Roman', serif"
          font-size="17"
          font-style="italic"
          opacity="0.6"
          transform="rotate(10)">ReLU</text
        >
        <text
          x="120"
          y="240"
          fill="#ea4335"
          font-family="'Times New Roman', serif"
          font-size="21"
          opacity="0.62"
          transform="rotate(-10)">∫f(x)dx</text
        >
        <text
          x="320"
          y="220"
          fill={siteConfig.accentColor}
          font-family="'Times New Roman', serif"
          font-size="18"
          font-style="italic"
          opacity="0.6"
          transform="rotate(12)">α·∇θ</text
        >
        <text
          x="450"
          y="240"
          fill="#fbbc04"
          font-family="'Times New Roman', serif"
          font-size="16"
          opacity="0.59"
          transform="rotate(-7)">log(p)</text
        >
        <text
          x="60"
          y="330"
          fill="#34a853"
          font-family="'Times New Roman', serif"
          font-size="20"
          opacity="0.61"
          transform="rotate(9)">∑ᵢ xᵢ</text
        >
        <text
          x="220"
          y="350"
          fill="#ea4335"
          font-family="'Times New Roman', serif"
          font-size="17"
          font-style="italic"
          opacity="0.6"
          transform="rotate(-14)">softmax</text
        >
        <text
          x="380"
          y="340"
          fill={siteConfig.accentColor}
          font-family="'Times New Roman', serif"
          font-size="19"
          opacity="0.63"
          transform="rotate(6)">W·X+b</text
        >
        <text
          x="140"
          y="440"
          fill="#fbbc04"
          font-family="'Times New Roman', serif"
          font-size="18"
          font-style="italic"
          opacity="0.61"
          transform="rotate(-11)">||x||₂</text
        >
        <text
          x="300"
          y="460"
          fill="#34a853"
          font-family="'Times New Roman', serif"
          font-size="16"
          opacity="0.59"
          transform="rotate(13)">tanh(x)</text
        >
        <text
          x="440"
          y="450"
          fill="#ea4335"
          font-family="'Times New Roman', serif"
          font-size="20"
          opacity="0.62"
          transform="rotate(-9)">λ·||θ||</text
        >
        <!-- Small mathematical symbols scattered -->
        <circle cx="360" cy="100" r="2" fill={siteConfig.accentColor} opacity="0.55"/>
        <circle cx="150" cy="190" r="2" fill="#34a853" opacity="0.55"/>
        <circle cx="280" cy="310" r="2" fill="#ea4335" opacity="0.55"/>
        <circle cx="90" cy="400" r="2" fill="#fbbc04" opacity="0.55"/>
        <!-- Graph-like elements -->
        <path d="M 10 100 Q 40 80 70 100 T 130 100" stroke={siteConfig.accentColor} stroke-width="2" fill="none" opacity="0.5"/>
        <path d="M 350 300 Q 380 280 410 300 T 470 300" stroke="#34a853" stroke-width="2" fill="none" opacity="0.5"/>
        <path d="M 200 400 L 230 380 L 260 390 L 290 370" stroke="#ea4335" stroke-width="2" fill="none" opacity="0.5"/>
      </pattern>
    </defs>
    <rect
      fill="url(#programming-symbols)"
      width="100%"
      height="100%"
      opacity="0.9"></rect>
    <rect
      fill="url(#0787a7c5-978c-4f66-83c7-11c213f99cb7)"
      width="100%"
      height="100%"
      stroke-width={0}></rect>
  </svg>
  <div class="h-full mx-auto p-8 sm:p-12 md:p-24 flex items-center">
    <div>
      <h2
        class="text-pretty text-xl sm:text-2xl md:text-5xl font-bold tracking-tight text-gray-700 animate-fade-in"
      >
        Hello! 👋
      </h2>
      <h1
        class="mt-6 sm:mt-8 md:mt-10 text-pretty text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-bold tracking-tight text-gray-800 animate-fade-in animation-delay-200"
      >
        I'm <span style={{ color: siteConfig.accentColor }} id="name-text"
          >{siteConfig.name}</span
        >
      </h1>
      <p
        class="mt-4 sm:mt-6 md:mt-8 text-pretty text-base sm:text-lg md:text-xl/8 font-medium text-gray-600"
      >
        <span id="typing-text" class="typing-animation"></span><span class="cursor-blink">|</span>
      </p>
      
      <!-- Social Icons -->
      <div class="mt-6 flex gap-4 animate-fade-in animation-delay-400">
        {siteConfig.social?.email && (
          <a
            href={`mailto:${siteConfig.social.email}`}
            aria-label="Email"
            class="social-icon-realistic email-icon transition-all duration-300 hover:scale-110"
          >
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="40" height="40" rx="8" fill="#EA4335"/>
              <path d="M11 14L20 20L29 14" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <rect x="11" y="14" width="18" height="12" rx="2" stroke="white" stroke-width="2" fill="none"/>
            </svg>
          </a>
        )}
        {siteConfig.social?.linkedin && (
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="social-icon-realistic linkedin-icon transition-all duration-300 hover:scale-110"
          >
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="40" height="40" rx="8" fill="#0A66C2"/>
              <path d="M15 17V27M15 14V14.5M21 27V22C21 20 22 19 24 19C26 19 27 20 27 22V27" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="15" cy="14" r="1.5" fill="white"/>
            </svg>
          </a>
        )}
        {siteConfig.social?.twitter && (
          <a
            href={siteConfig.social.twitter}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X (Twitter)"
            class="social-icon-realistic x-icon transition-all duration-300 hover:scale-110"
          >
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="40" height="40" rx="8" fill="#000000"/>
              <line x1="12" y1="12" x2="28" y2="28" stroke="white" stroke-width="3" stroke-linecap="round"/>
              <line x1="28" y1="12" x2="12" y2="28" stroke="white" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </a>
        )}
        {siteConfig.social?.github && (
          <a
            href={siteConfig.social.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="social-icon-realistic github-icon transition-all duration-300 hover:scale-110"
          >
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="40" height="40" rx="8" fill="#181717"/>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M20 11C15.03 11 11 15.03 11 20C11 24.08 13.58 27.53 17.15 28.71C17.65 28.8 17.83 28.49 17.83 28.22C17.83 27.98 17.82 27.22 17.82 26.42C15.5 26.98 14.93 25.46 14.93 25.46C14.48 24.42 13.83 24.11 13.83 24.11C12.93 23.54 13.9 23.55 13.9 23.55C14.9 23.62 15.42 24.53 15.42 24.53C16.31 25.97 17.73 25.53 17.85 25.27C17.94 24.63 18.2 24.19 18.49 23.94C16.71 23.69 14.85 22.95 14.85 19.77C14.85 18.76 15.22 17.94 15.43 17.29C15.33 17.04 15 16.16 15.53 14.92C15.53 14.92 16.38 14.65 17.82 15.63C18.63 15.41 19.32 15.3 20 15.3C20.68 15.3 21.37 15.41 22.18 15.63C23.62 14.65 24.47 14.92 24.47 14.92C25 16.16 24.67 17.04 24.57 17.29C24.78 17.94 25.15 18.76 25.15 19.77C25.15 22.96 23.28 23.68 21.49 23.93C21.84 24.24 22.17 24.85 22.17 25.79C22.17 27.13 22.16 28.21 22.16 28.22C22.16 28.49 22.34 28.8 22.85 28.71C26.42 27.53 29 24.08 29 20C29 15.03 24.97 11 20 11Z" fill="white"/>
            </svg>
          </a>
        )}
      </div>
      
      <!-- AI/ML Focus Badge -->
      <div class="mt-6 sm:mt-8 flex flex-wrap gap-3 animate-fade-in animation-delay-600">
        <span class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-blue-50 via-blue-100 to-blue-50 px-4 py-2 text-sm font-medium text-[#4285f4] border border-[#4285f4]/30 transition-all duration-500 hover:shadow-lg hover:shadow-[#4285f4]/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
          </svg>
          LLMs & RAG
        </span>
        <span class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-red-50 via-red-100 to-red-50 px-4 py-2 text-sm font-medium text-[#ea4335] border border-[#ea4335]/30 transition-all duration-500 hover:shadow-lg hover:shadow-[#ea4335]/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"></rect>
            <rect x="14" y="3" width="7" height="7"></rect>
            <rect x="14" y="14" width="7" height="7"></rect>
            <rect x="3" y="14" width="7" height="7"></rect>
          </svg>
          Computer Vision
        </span>
        <span class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-green-50 via-green-100 to-green-50 px-4 py-2 text-sm font-medium text-[#34a853] border border-[#34a853]/30 transition-all duration-500 hover:shadow-lg hover:shadow-[#34a853]/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
          </svg>
          MLOps & Scalability
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }

  .animation-delay-400 {
    animation-delay: 0.4s;
  }

  .animation-delay-600 {
    animation-delay: 0.6s;
  }

  /* Social icon hover effects */
  .social-icon-realistic {
    display: inline-block;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .social-icon-realistic:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    transform: translateY(-2px);
  }

  .email-icon:hover svg rect {
    fill: #d32f2f;
  }

  .linkedin-icon:hover svg rect {
    fill: #0052a3;
  }

  .x-icon:hover svg rect {
    fill: #1a1a1a;
  }

  .github-icon:hover svg rect {
    fill: #0d1117;
  }

  .typing-animation {
    display: inline-block;
    min-height: 1.5em;
  }

  .cursor-blink {
    display: inline-block;
    animation: blink 1s step-end infinite;
    color: var(--accent-color);
    font-weight: bold;
    margin-left: 2px;
  }

  @keyframes blink {
    0%, 50% {
      opacity: 1;
    }
    51%, 100% {
      opacity: 0;
    }
  }
</style>

<script define:vars={{ title: siteConfig.title }}>
  // Typing animation
  const typingElement = document.getElementById('typing-text');
  const texts = [
    title,
    'Building AI Systems',
    'LLM Specialist',
    'Computer Vision Expert',
    'MLOps Engineer'
  ];
  
  let textIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  let typeSpeed = 100;

  function typeText() {
    if (!typingElement) return;

    const currentText = texts[textIndex];
    
    if (!isDeleting) {
      typingElement.textContent = currentText.substring(0, charIndex + 1);
      charIndex++;
      
      if (charIndex === currentText.length) {
        isDeleting = true;
        typeSpeed = 2000; // Pause at end
      } else {
        typeSpeed = 100;
      }
    } else {
      typingElement.textContent = currentText.substring(0, charIndex - 1);
      charIndex--;
      
      if (charIndex === 0) {
        isDeleting = false;
        textIndex = (textIndex + 1) % texts.length;
        typeSpeed = 500; // Pause before next text
      } else {
        typeSpeed = 50;
      }
    }
    
    setTimeout(typeText, typeSpeed);
  }

  // Start typing after page loads
  window.addEventListener('load', () => {
    setTimeout(() => {
      typeText();
    }, 2500); // Start after loader finishes
  });
</script>
