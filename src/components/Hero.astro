---
import { siteConfig } from "../config";
---

<section id="hero" class="scroll-reveal w-full">
  <div class="flex flex-col-reverse sm:flex-row justify-between items-start gap-8">
    <div class="flex-1">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight mb-2">
        {siteConfig.name}
      </h1>
      <h2 class="text-mono text-sm sm:text-base text-gray-600 mb-6">
        {siteConfig.title}
      </h2>

      <div class="flex flex-wrap items-center gap-3">
        {siteConfig.social.email && (
          <a href={`mailto:${siteConfig.social.email}`} class="social-btn" title="Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#EA4335" xmlns="http://www.w3.org/2000/svg">
              <path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/>
            </svg>
          </a>
        )}
        {siteConfig.social.github && (
          <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="social-btn" title="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#181717" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        )}
        {siteConfig.social.linkedin && (
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="social-btn" title="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#0A66C2" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        )}
        {siteConfig.social.twitter && (
          <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" class="social-btn" title="X (Twitter)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#000000" xmlns="http://www.w3.org/2000/svg">
              <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z" />
            </svg>
          </a>
        )}
        
        {siteConfig.resumeLink && (
          <a
            href={siteConfig.resumeLink}
            target="_blank"
            rel="noopener noreferrer"
            class="cv-btn"
            download="Sarvagya_Gupta_Resume.pdf"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="16" y1="13" x2="8" y2="13" />
              <line x1="16" y1="17" x2="8" y2="17" />
              <polyline points="10 9 9 9 8 9" />
            </svg>
            CV
          </a>
        )}
      </div>
    </div>

    <!-- Avatar -->
    <div class="self-center sm:self-start w-32 h-32 sm:w-40 sm:h-40 rounded-full flex-shrink-0 overflow-hidden flex items-center justify-center bg-gray-100 border-4 border-white shadow-lg ring-1 ring-gray-200">
      {siteConfig.profileImage ? (
        <img src={siteConfig.profileImage} alt={siteConfig.name} class="w-full h-full object-cover" />
      ) : (
        <span class="text-4xl" role="img" aria-label="avatar">👨‍💻</span>
      )}
    </div>
  </div>
</section>

<style>
  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    color: #4b5563;
    background: transparent;
    transition: all 0.2s ease;
  }

  .social-btn:hover {
    background: #f3f4f6;
    color: #111827;
  }

  .social-btn :global(svg) {
    width: 18px;
    height: 18px;
  }

  .cv-btn {
    display: flex;
    align-items: center;
    height: 36px;
    padding: 0 16px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: #4b5563;
    background: transparent;
    transition: all 0.2s ease;
  }

  .cv-btn:hover {
    background: #f3f4f6;
    color: #111827;
  }
</style>
