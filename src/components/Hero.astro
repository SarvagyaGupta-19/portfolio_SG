---
import { siteConfig } from "../config";
import HeroBackground from "./HeroBackground.astro";

---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-white py-24 md:h-screen"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <!-- Gradient overlay and SVG Background -->
  <HeroBackground />

  <div class="h-full mx-auto px-8 sm:px-12 md:px-24 py-16 sm:py-20 md:py-24 flex items-center">
    <div class="max-w-5xl">
      <h2
        class="text-xl sm:text-2xl md:text-3xl font-bold tracking-tight text-gray-700 animate-fade-in"
        style="line-height: 1.4; margin-bottom: 1.5rem;"
      >
        Hello! 👋
      </h2>
      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-gray-900 animate-fade-in animation-delay-200"
        style="line-height: 1.1; margin-bottom: 1.5rem;"
      >
        I'm <span style={{ color: siteConfig.accentColor }} id="name-text">{siteConfig.name}</span>
      </h1>
      <!-- AI/ML Focus Badge (Moved Up) -->
      <div
        class="mt-4 flex flex-wrap gap-3 scroll-reveal animate-fade-in animation-delay-200"
        style="margin-bottom: 2rem;"
      >
        <span
          class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-blue-50 via-blue-100 to-blue-50 px-4 py-2 text-sm font-medium text-[#4285f4] border border-[#4285f4]/30 transition-all duration-500 hover:shadow-lg hover:shadow-[#4285f4]/20"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
            ></path>
          </svg>
          AI/ML Engineer
        </span>
        <span
          class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-red-50 via-red-100 to-red-50 px-4 py-2 text-sm font-medium text-[#ea4335] border border-[#ea4335]/30 transition-all duration-500 hover:shadow-lg hover:shadow-[#ea4335]/20"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <rect x="3" y="3" width="7" height="7"></rect>
            <rect x="14" y="3" width="7" height="7"></rect>
            <rect x="14" y="14" width="7" height="7"></rect>
            <rect x="3" y="14" width="7" height="7"></rect>
          </svg>
          LLMs & RAG
        </span>
        <span
          class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-green-50 via-green-100 to-green-50 px-4 py-2 text-sm font-medium text-[#34a853] border border-[#34a853]/30 transition-all duration-500 hover:shadow-lg hover:shadow-[#34a853]/20"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
          </svg>
          Agentic AI
        </span>
      </div>

      <!-- Social Icons -->
      <div class="mt-8 animate-fade-in animation-delay-400">
        <p class="text-sm font-medium text-gray-600 mb-3">Let's Connect</p>
        <div class="flex gap-4">
          {
            siteConfig.social?.email && (
              <a
                href={`mailto:${siteConfig.social.email}`}
                aria-label="Email"
                class="social-icon group"
              >
                <div class="icon-container">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon-svg"
                  >
                    <rect x="2" y="4" width="20" height="16" rx="2" />
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                  </svg>
                </div>
              </a>
            )
          }
          {
            siteConfig.social?.linkedin && (
              <a
                href={siteConfig.social.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"
                class="social-icon group"
              >
                <div class="icon-container">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="icon-svg"
                  >
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                </div>
              </a>
            )
          }
          {
            siteConfig.social?.twitter && (
              <a
                href={siteConfig.social.twitter}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="X (Twitter)"
                class="social-icon group"
              >
                <div class="icon-container">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="icon-svg"
                  >
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                  </svg>
                </div>
              </a>
            )
          }
          {
            siteConfig.social?.github && (
              <a
                href={siteConfig.social.github}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
                class="social-icon group"
              >
                <div class="icon-container">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="icon-svg"
                  >
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                  </svg>
                </div>
              </a>
            )
          }
        </div>

        <!-- Resume Download Button -->
        {
          siteConfig.resumeLink && (
            <div class="mt-6 animate-fade-in animation-delay-700">
              <a
                href={siteConfig.resumeLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium text-white transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
                style={`background-color: ${siteConfig.accentColor}`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                Download Resume
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>

  <style>
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in {
      animation: fadeIn 0.8s ease-out forwards;
      opacity: 0;
    }

    .animation-delay-200 {
      animation-delay: 0.2s;
    }

    .animation-delay-400 {
      animation-delay: 0.4s;
    }

    .animation-delay-600 {
      animation-delay: 0.6s;
    }

    .animation-delay-700 {
      animation-delay: 0.7s;
    }

    /* Social icon hover effects with glassmorphic blend */
    .social-icon {
      display: inline-flex;
      text-decoration: none;
      position: relative;
    }

    .icon-container {
      position: relative;
      width: 52px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: white;
      border: 2px solid rgba(229, 231, 235, 0.6);
      border-radius: 14px;
      transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
      overflow: hidden;
    }

    .icon-container::before {
      content: "";
      position: absolute;
      inset: 0;
      background: currentColor;
      opacity: 0;
      transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
      border-radius: 12px;
    }

    .social-icon:hover .icon-container {
      transform: translateY(-4px) scale(1.05);
      border-color: transparent;
      box-shadow: 0 12px 28px -8px currentColor;
    }

    .social-icon:hover .icon-container::before {
      opacity: 1;
    }

    .icon-svg {
      position: relative;
      z-index: 1;
      transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .social-icon:hover .icon-svg {
      color: white !important;
      transform: scale(1.1) rotate(5deg);
    }

    /* Email icon - Gmail red */
    .social-icon:nth-child(1) .icon-svg {
      color: #ea4335;
    }
    .social-icon:nth-child(1) .icon-container {
      color: #ea4335;
    }

    /* LinkedIn icon - LinkedIn blue */
    .social-icon:nth-child(2) .icon-svg {
      color: #0077b5;
    }
    .social-icon:nth-child(2) .icon-container {
      color: #0077b5;
    }

    /* X (Twitter) icon - Black */
    .social-icon:nth-child(3) .icon-svg {
      color: #000000;
    }
    .social-icon:nth-child(3) .icon-container {
      color: #000000;
    }

    /* GitHub icon - GitHub black */
    .social-icon:nth-child(4) .icon-svg {
      color: #181717;
    }
    .social-icon:nth-child(4) .icon-container {
      color: #181717;
    }
  </style>
</div>
