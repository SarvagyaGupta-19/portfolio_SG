---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{
  hasEducation && (
    <section id="education" class="w-full">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Education</h2>

      <div class="space-y-4">
        {siteConfig.education.map((edu) => (
          <div class="edu-card border border-gray-100 rounded-xl p-6 bg-white transition-all hover:border-gray-300 hover:shadow-sm">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
              <div class="flex items-start gap-3">
                {edu.logo && (
                  <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-gray-50 border border-gray-100 rounded-lg overflow-hidden mt-1">
                    <img src={edu.logo} alt={edu.school} class="w-full h-full object-contain p-1" loading="lazy" />
                  </div>
                )}
                <div>
                  <h3 class="text-base font-semibold text-gray-900">{edu.school}</h3>
                  <p class="text-mono text-sm text-gray-500 mt-1">{edu.degree}</p>
                  {edu.achievements && edu.achievements.length > 0 && (
                    <p class="text-mono text-xs text-gray-400 mt-2">{edu.achievements[0]}</p>
                  )}
                </div>
              </div>
              <span class="text-mono text-sm text-gray-500 flex-shrink-0 whitespace-nowrap">
                {edu.dateRange}
              </span>
            </div>
          </div>
        ))}
      </div>
    </section>
  )
}
