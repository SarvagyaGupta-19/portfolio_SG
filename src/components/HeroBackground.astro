---
import { siteConfig } from "../config";
---

<div
  class="absolute inset-0 -z-10"
  style={`background: radial-gradient(ellipse 800px 1200px at 0% 0%, ${siteConfig.accentColor}40 0%, ${siteConfig.accentColor}25 20%, ${siteConfig.accentColor}10 40%, rgba(255, 255, 255, 0.3) 70%, rgba(255, 255, 255, 0.8) 90%, white 100%)`}
>
</div>
<svg
  aria-hidden="true"
  class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
>
  <defs>
    <pattern
      x="50%"
      y={-1}
      id="0787a7c5-978c-4f66-83c7-11c213f99cb7"
      width={200}
      height={200}
      patternUnits="userSpaceOnUse"
    >
      <path d="M.5 200V.5H200" fill="none"></path>
    </pattern>
    <pattern
      id="programming-symbols"
      x="0"
      y="0"
      width="800"
      height="800"
      patternUnits="userSpaceOnUse"
    >
      <!-- Row 1: Top equations - well spaced -->
      <text
        x="50"
        y="60"
        fill={siteConfig.accentColor}
        font-family="'Times New Roman', serif"
        font-size="26"
        font-style="italic"
        opacity="0.7"
        transform="rotate(-8)">∂L/∂θ</text
      >
      <text
        x="220"
        y="65"
        fill="#34a853"
        font-family="'Times New Roman', serif"
        font-size="24"
        opacity="0.68"
        transform="rotate(6)">∇f(x)</text
      >
      <text
        x="390"
        y="55"
        fill="#ea4335"
        font-family="'Times New Roman', serif"
        font-size="28"
        font-style="italic"
        opacity="0.72"
        transform="rotate(-4)">σ(z)</text
      >
      <text
        x="570"
        y="70"
        fill="#fbbc04"
        font-family="'Times New Roman', serif"
        font-size="22"
        opacity="0.65"
        transform="rotate(7)">E[X²]</text
      >

      <!-- Graph 1: Neural activation curve -->
      <path
        d="M 30 130 Q 80 100 130 130 Q 180 160 230 130"
        stroke={siteConfig.accentColor}
        stroke-width="3"
        fill="none"
        opacity="0.6"></path>
      <circle cx="130" cy="130" r="4" fill={siteConfig.accentColor} opacity="0.7"></circle>

      <!-- Row 2: ML fundamentals -->
      <text
        x="280"
        y="145"
        fill="#34a853"
        font-family="'Times New Roman', serif"
        font-size="25"
        font-style="italic"
        opacity="0.7"
        transform="rotate(9)">Σwᵢxᵢ</text
      >
      <text
        x="470"
        y="140"
        fill="#ea4335"
        font-family="'Times New Roman', serif"
        font-size="23"
        opacity="0.68"
        transform="rotate(-7)">ReLU(x)</text
      >
      <text
        x="650"
        y="150"
        fill={siteConfig.accentColor}
        font-family="'Times New Roman', serif"
        font-size="21"
        opacity="0.66"
        transform="rotate(5)">W·X+b</text
      >

      <!-- Graph 2: Step function visualization -->
      <path
        d="M 50 230 L 120 230 L 120 200 L 190 200"
        stroke="#34a853"
        stroke-width="3"
        fill="none"
        opacity="0.6"></path>
      <circle cx="120" cy="215" r="4" fill="#34a853" opacity="0.7"></circle>

      <!-- Row 3: Advanced concepts -->
      <text
        x="260"
        y="225"
        fill="#fbbc04"
        font-family="'Times New Roman', serif"
        font-size="27"
        opacity="0.7"
        transform="rotate(-6)">∫₀^∞f(x)dx</text
      >
      <text
        x="490"
        y="235"
        fill={siteConfig.accentColor}
        font-family="'Times New Roman', serif"
        font-size="24"
        font-style="italic"
        opacity="0.68"
        transform="rotate(8)">log(p(y|x))</text
      >
      <text
        x="700"
        y="220"
        fill="#34a853"
        font-family="'Times New Roman', serif"
        font-size="22"
        opacity="0.66"
        transform="rotate(-5)">KL(P||Q)</text
      >

      <!-- Graph 3: Loss curve descent -->
      <path
        d="M 80 310 Q 130 280 180 300 Q 230 320 280 310 Q 330 300 380 305"
        stroke="#ea4335"
        stroke-width="3"
        fill="none"
        opacity="0.6"
        stroke-dasharray="5,3"></path>
      <circle cx="180" cy="300" r="4" fill="#ea4335" opacity="0.7"></circle>
      <circle cx="330" cy="300" r="4" fill="#ea4335" opacity="0.7"></circle>

      <!-- Row 4: Optimization & activation -->
      <text
        x="440"
        y="325"
        fill="#ea4335"
        font-family="'Times New Roman', serif"
        font-size="26"
        opacity="0.7"
        transform="rotate(7)">α·∇θₜ</text
      >
      <text
        x="620"
        y="315"
        fill="#fbbc04"
        font-family="'Times New Roman', serif"
        font-size="23"
        font-style="italic"
        opacity="0.68"
        transform="rotate(-8)">softmax(z)</text
      >

      <!-- Row 5: Deep learning operations -->
      <text
        x="60"
        y="400"
        fill={siteConfig.accentColor}
        font-family="'Times New Roman', serif"
        font-size="25"
        opacity="0.7"
        transform="rotate(6)">∑ᵢ₌₁ⁿ xᵢ</text
      >
      <text
        x="270"
        y="410"
        fill="#34a853"
        font-family="'Times New Roman', serif"
        font-size="24"
        font-style="italic"
        opacity="0.68"
        transform="rotate(-7)">BatchNorm</text
      >
      <text
        x="490"
        y="395"
        fill="#ea4335"
        font-family="'Times New Roman', serif"
        font-size="22"
        opacity="0.66"
        transform="rotate(9)">||x||₂</text
      >
      <text
        x="660"
        y="405"
        fill="#fbbc04"
        font-family="'Times New Roman', serif"
        font-size="26"
        opacity="0.7"
        transform="rotate(-5)">tanh(x)</text
      >

      <!-- Graph 4: Sigmoid-like curve -->
      <path
        d="M 40 490 C 90 490, 110 470, 140 470 S 190 490, 240 490"
        stroke="#fbbc04"
        stroke-width="3"
        fill="none"
        opacity="0.6"></path>
      <circle cx="140" cy="470" r="4" fill="#fbbc04" opacity="0.7"></circle>

      <!-- Row 6: Modern architectures -->
      <text
        x="300"
        y="485"
        fill={siteConfig.accentColor}
        font-family="'Times New Roman', serif"
        font-size="28"
        opacity="0.72"
        transform="rotate(8)">Attention(Q,K,V)</text
      >
      <text
        x="610"
        y="495"
        fill="#34a853"
        font-family="'Times New Roman', serif"
        font-size="23"
        font-style="italic"
        opacity="0.68"
        transform="rotate(-6)">Transformer</text
      >

      <!-- Graph 5: Multi-layer network visualization -->
      <g opacity="0.6">
        <circle cx="80" cy="570" r="5" fill={siteConfig.accentColor}></circle>
        <circle cx="80" cy="600" r="5" fill={siteConfig.accentColor}></circle>
        <circle cx="80" cy="630" r="5" fill={siteConfig.accentColor}></circle>
        <circle cx="160" cy="585" r="5" fill="#34a853"></circle>
        <circle cx="160" cy="615" r="5" fill="#34a853"></circle>
        <line x1="80" y1="570" x2="160" y2="585" stroke="#999" stroke-width="1.5"></line>
        <line x1="80" y1="600" x2="160" y2="585" stroke="#999" stroke-width="1.5"></line>
        <line x1="80" y1="630" x2="160" y2="615" stroke="#999" stroke-width="1.5"></line>
        <line x1="80" y1="600" x2="160" y2="615" stroke="#999" stroke-width="1.5"></line>
      </g>

      <!-- Row 7: Regularization & loss -->
      <text
        x="260"
        y="575"
        fill="#ea4335"
        font-family="'Times New Roman', serif"
        font-size="25"
        opacity="0.7"
        transform="rotate(7)">λ·||θ||₁</text
      >
      <text
        x="450"
        y="585"
        fill="#fbbc04"
        font-family="'Times New Roman', serif"
        font-size="24"
        font-style="italic"
        opacity="0.68"
        transform="rotate(-8)">Dropout(p)</text
      >
      <text
        x="640"
        y="570"
        fill={siteConfig.accentColor}
        font-family="'Times New Roman', serif"
        font-size="22"
        opacity="0.66"
        transform="rotate(6)">H(X,Y)</text
      >

      <!-- Graph 6: Probability distribution -->
      <path
        d="M 340 660 L 370 640 L 400 665 L 430 645 L 460 660 L 490 650"
        stroke="#34a853"
        stroke-width="3"
        fill="none"
        opacity="0.6"></path>
      <circle cx="400" cy="665" r="4" fill="#34a853" opacity="0.7"></circle>

      <!-- Row 8: Popular models & techniques -->
      <text
        x="50"
        y="670"
        fill="#34a853"
        font-family="'Times New Roman', serif"
        font-size="26"
        opacity="0.7"
        transform="rotate(-7)">∂²L/∂θ²</text
      >
      <text
        x="240"
        y="680"
        fill="#ea4335"
        font-family="'Times New Roman', serif"
        font-size="24"
        font-style="italic"
        opacity="0.68"
        transform="rotate(9)">ResNet</text
      >

      <text
        x="540"
        y="675"
        fill="#fbbc04"
        font-family="'Times New Roman', serif"
        font-size="23"
        opacity="0.66"
        transform="rotate(-6)">max(0,x)</text
      >
      <text
        x="710"
        y="685"
        fill={siteConfig.accentColor}
        font-family="'Times New Roman', serif"
        font-size="21"
        opacity="0.65"
        transform="rotate(7)">CNN</text
      >

      <!-- Row 9: Advanced architectures -->
      <text
        x="80"
        y="750"
        fill={siteConfig.accentColor}
        font-family="'Times New Roman', serif"
        font-size="25"
        opacity="0.7"
        transform="rotate(8)">LSTM</text
      >
      <text
        x="230"
        y="760"
        fill="#34a853"
        font-family="'Times New Roman', serif"
        font-size="27"
        font-style="italic"
        opacity="0.72"
        transform="rotate(-5)">GRU</text
      >
      <text
        x="400"
        y="755"
        fill="#ea4335"
        font-family="'Times New Roman', serif"
        font-size="24"
        opacity="0.68"
        transform="rotate(6)">BERT</text
      >
      <text
        x="570"
        y="765"
        fill="#fbbc04"
        font-family="'Times New Roman', serif"
        font-size="22"
        opacity="0.66"
        transform="rotate(-7)">GPT</text
      >
      <text
        x="700"
        y="750"
        fill={siteConfig.accentColor}
        font-family="'Times New Roman', serif"
        font-size="23"
        opacity="0.67"
        transform="rotate(8)">VAE</text
      >

      <!-- Graph 7: GAN-like distribution -->
      <path
        d="M 520 140 Q 550 120 580 140 Q 610 160 640 140"
        stroke="#ea4335"
        stroke-width="3"
        fill="none"
        opacity="0.6"></path>
      <path
        d="M 530 145 Q 560 165 590 145 Q 620 125 650 145"
        stroke="#fbbc04"
        stroke-width="3"
        fill="none"
        opacity="0.55"
        stroke-dasharray="4,2"></path>
    </pattern>
  </defs>
  <rect fill="url(#programming-symbols)" width="100%" height="100%" opacity="0.9"></rect>
  <rect
    fill="url(#0787a7c5-978c-4f66-83c7-11c213f99cb7)"
    width="100%"
    height="100%"
    stroke-width={0}></rect>
</svg>
