---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="w-full pt-16">
      <h2 class="text-xl font-bold text-gray-900 mb-8">Projects</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {siteConfig.projects.map((project, index) => (
          <div class="project-card flex flex-col p-6 rounded-xl border border-transparent bg-white h-full scroll-reveal">
            <h3 class="text-base font-bold text-gray-900 mb-3">{project.name}</h3>
            
            <p class="text-mono text-xs leading-relaxed text-gray-500 mb-6">
              {project.description}
            </p>
            
            <div class="flex flex-wrap gap-4 mb-5 mt-auto">
              {project.liveDemo && (
                <a href={project.liveDemo} target="_blank" rel="noopener noreferrer" class="text-xs font-medium flex items-center gap-1.5 text-gray-700 hover:text-gray-900 transition-colors">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                  Live Demo
                </a>
              )}
              {project.link && (
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-xs font-medium flex items-center gap-1.5 text-gray-700 hover:text-gray-900 transition-colors">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                  </svg>
                  GitHub
                </a>
              )}
            </div>
            
            <div class="flex flex-wrap gap-2 pt-4 border-t border-gray-100">
              {project.skills.map((skill) => (
                <span class="rounded-full bg-gray-100 px-3 py-1 text-[10px] font-medium text-gray-700">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )
}
