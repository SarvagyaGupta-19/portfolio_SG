---
import { siteConfig } from "../config";

const hasGithubStats = siteConfig.githubStats && siteConfig.githubUsername;
---

{hasGithubStats && (
  <div id="github-stats" class="relative w-full overflow-hidden bg-[#0d1117] py-24 text-white">
    {/* Stars Background Effect */}
    <div class="absolute inset-0 opacity-30">
      {[...Array(50)].map((_, i) => (
        <div 
          class="absolute h-1 w-1 rounded-full bg-white animate-twinkle"
          style={`
            left: ${Math.random() * 100}%;
            top: ${Math.random() * 100}%;
            animation-delay: ${Math.random() * 3}s;
            opacity: ${Math.random() * 0.7 + 0.3};
          `}
        ></div>
      ))}
    </div>

    <div class="container relative z-10 mx-auto max-w-7xl px-6">
      {/* Section Header */}
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-4xl font-bold md:text-5xl">
          Days I <span class="bg-gradient-to-r from-[var(--accent-color)] to-[#34a853] bg-clip-text text-transparent">Code</span>
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-gray-400">
          Consistent contributions and continuous learning throughout the year
        </p>
      </div>

      {/* GitHub Stats Cards */}
      <div class="mb-12 grid grid-cols-1 gap-6 md:grid-cols-3">
        {/* Total Contributions */}
        <div class="group relative overflow-hidden rounded-2xl border border-gray-700 bg-[#161b22] p-6 transition-all duration-300 hover:scale-105 hover:border-[var(--accent-color)]">
          <div class="absolute right-0 top-0 h-32 w-32 bg-gradient-to-br from-[var(--accent-color)]/20 to-[#ea4335]/20 blur-3xl"></div>
          <div class="relative z-10">
            <div class="mb-2 text-sm font-medium text-gray-400">Total Contributions</div>
            <div class="mb-1 text-4xl font-bold text-[var(--accent-color)]">
              {siteConfig.githubStats.totalContributions}
            </div>
            <div class="text-xs text-gray-500">in the last year</div>
          </div>
        </div>

        {/* Current Streak */}
        <div class="group relative overflow-hidden rounded-2xl border border-gray-700 bg-[#161b22] p-6 transition-all duration-300 hover:scale-105 hover:border-[#4285f4]">
          <div class="absolute right-0 top-0 h-32 w-32 bg-gradient-to-br from-[#fbbc04]/20 to-[#ea4335]/20 blur-3xl"></div>
          <div class="relative z-10">
            <div class="mb-2 text-sm font-medium text-gray-400">Current Streak</div>
            <div class="mb-1 text-4xl font-bold text-[#4285f4]">
              {siteConfig.githubStats.currentStreak}
            </div>
            <div class="text-xs text-gray-500">consecutive days</div>
          </div>
        </div>

        {/* Longest Streak */}
        <div class="group relative overflow-hidden rounded-2xl border border-gray-700 bg-[#161b22] p-6 transition-all duration-300 hover:scale-105 hover:border-pink-500">
          <div class="absolute right-0 top-0 h-32 w-32 bg-gradient-to-br from-pink-500/20 to-orange-500/20 blur-3xl"></div>
          <div class="relative z-10">
            <div class="mb-2 text-sm font-medium text-gray-400">Longest Streak</div>
            <div class="mb-1 text-4xl font-bold text-pink-400">
              {siteConfig.githubStats.longestStreak}
            </div>
            <div class="text-xs text-gray-500">consecutive days</div>
          </div>
        </div>
      </div>

      {/* GitHub Contribution Graph Visualization */}
      <div class="overflow-hidden rounded-2xl border border-gray-700 bg-[#0d1117] p-8">
        <div class="mb-6 flex items-center justify-between">
          <h3 class="text-xl font-semibold">Contribution Activity</h3>
          <div class="flex items-center gap-2 text-sm text-gray-400">
            <span>Less</span>
            <div class="flex gap-1">
              <div class="h-3 w-3 rounded-sm bg-[#161b22] border border-gray-700"></div>
              <div class="h-3 w-3 rounded-sm" style="background-color: rgba(139, 92, 246, 0.3)"></div>
              <div class="h-3 w-3 rounded-sm" style="background-color: rgba(139, 92, 246, 0.5)"></div>
              <div class="h-3 w-3 rounded-sm" style="background-color: rgba(139, 92, 246, 0.7)"></div>
              <div class="h-3 w-3 rounded-sm" style="background-color: rgba(139, 92, 246, 1)"></div>
            </div>
            <span>More</span>
          </div>
        </div>

        {/* Contribution Grid */}
        <div class="overflow-x-auto">
          <div class="inline-grid grid-flow-col gap-1" style="grid-template-rows: repeat(7, 1fr);">
            {/* Generate contribution squares (52 weeks × 7 days = 364 squares) */}
            {[...Array(364)].map((_, i) => {
              const intensity = Math.floor(Math.random() * 5);
              const colors = ['#161b22', 'rgba(139, 92, 246, 0.3)', 'rgba(139, 92, 246, 0.5)', 'rgba(139, 92, 246, 0.7)', 'rgba(139, 92, 246, 1)'];
              return (
                <div
                  class="h-3 w-3 rounded-sm transition-all duration-200 hover:ring-2 hover:ring-[var(--accent-color)] hover:ring-offset-2 hover:ring-offset-[#0d1117] cursor-pointer border border-gray-800"
                  style={`background-color: ${colors[intensity]}`}
                  title={`${intensity} contributions`}
                ></div>
              );
            })}
          </div>
        </div>

        {/* Month Labels */}
        <div class="mt-4 flex justify-between text-xs text-gray-500">
          <span>Jan</span>
          <span>Feb</span>
          <span>Mar</span>
          <span>Apr</span>
          <span>May</span>
          <span>Jun</span>
          <span>Jul</span>
          <span>Aug</span>
          <span>Sep</span>
          <span>Oct</span>
          <span>Nov</span>
          <span>Dec</span>
        </div>
      </div>

      {/* GitHub Profile Link */}
      <div class="mt-8 text-center">
        <a 
          href={`https://github.com/${siteConfig.githubUsername}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-[#161b22] px-6 py-3 text-sm font-medium text-white transition-all duration-300 hover:bg-[var(--accent-color)] hover:scale-105 border border-gray-700"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View GitHub Profile
        </a>
      </div>
    </div>
  </div>
)}

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  :root {
    --accent-color: var(--accentColor);
  }
  
  @keyframes twinkle {
    0%, 100% {
      opacity: 0.3;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }

  .animate-twinkle {
    animation: twinkle 3s ease-in-out infinite;
  }
</style>
