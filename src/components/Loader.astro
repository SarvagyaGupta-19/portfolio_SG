---
import { siteConfig } from "../config";

const nameLetters = siteConfig.name.split("");
---

<div id="loader" style="position: fixed; inset: 0; z-index: 99999; background-color: white; display: flex; flex-direction: column; align-items: center; justify-content: center; transition: all 0.7s cubic-bezier(0.76,0,0.24,1);">
  <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: center; overflow: hidden; padding: 0.5rem 1rem; gap: 0.5em;">
    {siteConfig.name.split(" ").map((word, wordIndex, wordsArray) => {
      // Calculate a stable index offset for animation delays across multiple words
      const previousLettersCount = wordsArray.slice(0, wordIndex).join("").length;
      
      return (
        <div style="display: flex; white-space: nowrap;">
          {word.split("").map((letter, i) => (
            <div style="overflow: hidden; display: flex; align-items: center;">
              <span 
                class="loader-letter"
                style={`animation-delay: ${(previousLettersCount + i) * 0.05}s;`}
              >
                {letter}
              </span>
            </div>
          ))}
        </div>
      );
    })}
  </div>
  
  <div style="overflow: hidden; margin-top: 1.5rem; padding: 0 1rem; text-align: center;">
    <p class="loader-subtitle" style={`animation-delay: ${nameLetters.length * 0.05 + 0.2}s;`}>
      {siteConfig.summary ? siteConfig.title.toUpperCase() + " | " + siteConfig.name.toUpperCase() : siteConfig.title}
    </p>
  </div>
</div>

<style>
  .loader-letter {
    display: block;
    font-weight: 900;
    font-size: clamp(1.8rem, 8vw, 6rem);
    color: #111827;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    transform: translateY(120%);
    animation: rollUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .loader-subtitle {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.625rem, 2vw, 0.875rem);
    font-weight: 600;
    letter-spacing: 0.2em;
    color: #4b5563;
    text-transform: uppercase;
    transform: translateY(100%);
    opacity: 0;
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes rollUp {
    0% {
      transform: translateY(120%);
    }
    100% {
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    0% {
      transform: translateY(100%);
      opacity: 0;
    }
    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }

  #loader.hide {
    transform: translateY(-100%) !important;
    opacity: 0 !important;
    pointer-events: none;
  }
</style>

<style is:global>
  /* Hide scrollbar and content while loading */
  body.is-loading {
    overflow: hidden;
  }
  
  body.is-loading main > *:not(#loader),
  body.is-loading > button,
  body.is-loading > .bottom-nav {
    opacity: 0;
    visibility: hidden;
  }

  main > *:not(#loader),
  body > button,
  body > .bottom-nav {
    transition: opacity 0.8s ease;
  }
</style>

<script>
  const initLoader = () => {
    const loader = document.getElementById("loader");
    if (!loader) return;
    
    // Lock scrolling and hide content initially
    document.body.classList.add("is-loading");
    
    // We remove the loader after animations + short reading time (2.4s)
    setTimeout(() => {
      loader.classList.add("hide");
      document.body.classList.remove("is-loading");
      
      setTimeout(() => {
        loader.remove();
      }, 800); // Allow slide up animation to finish before removing from DOM
    }, 2400);
  };
  
  // Run it
  initLoader();
</script>
