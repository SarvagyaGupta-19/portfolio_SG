---
// Simple Google-Colored Loader
---

<div id="page-loader" class="loader-overlay">
  <div class="loader-container">
    <div class="google-spinner">
      <div class="spinner-segment blue"></div>
      <div class="spinner-segment red"></div>
      <div class="spinner-segment yellow"></div>
      <div class="spinner-segment green"></div>
    </div>
    <div class="loader-text">Loading</div>
  </div>
</div>

<script>
  const loader = document.getElementById('page-loader');
  
  // Remove loader with smooth transition
  window.addEventListener('load', () => {
    setTimeout(() => {
      if (loader) {
        loader.classList.add('fade-out');
        setTimeout(() => {
          loader.style.display = 'none';
          document.body.style.overflow = 'auto';
        }, 1200);
      }
    }, 1800);
  });

  // Fallback removal
  setTimeout(() => {
    if (loader && !loader.classList.contains('fade-out')) {
      loader.classList.add('fade-out');
      setTimeout(() => {
        if (loader) loader.style.display = 'none';
        document.body.style.overflow = 'auto';
      }, 1200);
    }
  }, 4000);
  
  document.body.style.overflow = 'hidden';
</script>

<style>
  .loader-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(249, 250, 251, 0.98) 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    transition: opacity 1.2s cubic-bezier(0.4, 0, 0.2, 1), 
                backdrop-filter 1.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .loader-overlay.fade-out {
    opacity: 0;
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    pointer-events: none;
  }

  .loader-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    animation: loaderFadeIn 0.8s ease-out;
  }

  @keyframes loaderFadeIn {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .google-spinner {
    width: 80px;
    height: 80px;
    position: relative;
    animation: rotate 1.4s linear infinite;
  }

  @keyframes rotate {
    to {
      transform: rotate(360deg);
    }
  }

  .spinner-segment {
    position: absolute;
    width: 100%;
    height: 100%;
    border: 4px solid transparent;
    border-radius: 50%;
  }

  .spinner-segment.blue {
    border-top-color: #4285F4;
    animation: segmentRotate 1.4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  .spinner-segment.red {
    border-right-color: #EA4335;
    animation: segmentRotate 1.4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    animation-delay: 0.35s;
  }

  .spinner-segment.yellow {
    border-bottom-color: #FBBC04;
    animation: segmentRotate 1.4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    animation-delay: 0.7s;
  }

  .spinner-segment.green {
    border-left-color: #34A853;
    animation: segmentRotate 1.4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    animation-delay: 1.05s;
  }

  @keyframes segmentRotate {
    0%, 25% {
      opacity: 0;
      transform: scale(0.8);
    }
    50% {
      opacity: 1;
      transform: scale(1);
    }
    75%, 100% {
      opacity: 0;
      transform: scale(0.8);
    }
  }

  .loader-text {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 1.25rem;
    font-weight: 500;
    background: linear-gradient(90deg, #4285F4 0%, #EA4335 25%, #FBBC04 50%, #34A853 75%, #4285F4 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: textShimmer 3s linear infinite;
  }

  @keyframes textShimmer {
    to {
      background-position: 200% center;
    }
  }

  @media (max-width: 768px) {
    .google-spinner {
      width: 60px;
      height: 60px;
    }

    .loader-text {
      font-size: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .google-spinner,
    .spinner-segment,
    .loader-text {
      animation: none;
    }
  }
</style>
